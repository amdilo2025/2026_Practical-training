{"ast":null,"code":"import { ref, onMounted } from \"vue\";\nimport { ElMessage } from \"element-plus\";\nimport { doctorApi, consultationApi } from \"../../api/index.js\";\nimport { useUserStore } from \"../../store/index.js\";\nexport default {\n  __name: 'DoctorConsult',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const userStore = useUserStore();\n    const doctors = ref([]);\n    const selectedDoctor = ref(null);\n    const consultContent = ref(\"\");\n    const history = ref([]);\n    const loading = ref(false);\n    const formatTime = t => t ? t.slice(0, 16).replace(\"T\", \" \") : \"\";\n    const loadData = async () => {\n      const dRes = await doctorApi.list();\n      if (dRes.code === 200) doctors.value = dRes.data || [];\n      const hRes = await consultationApi.listByUser(userStore.userId);\n      if (hRes.code === 200) history.value = hRes.data || [];\n    };\n    const handleSubmit = async () => {\n      if (!consultContent.value.trim()) return ElMessage.warning(\"请输入问题\");\n      if (!selectedDoctor.value) return ElMessage.warning(\"请选择医师\");\n      loading.value = true;\n      try {\n        await consultationApi.add({\n          userId: userStore.userId,\n          doctorId: selectedDoctor.value.id,\n          content: consultContent.value\n        });\n        ElMessage.success(\"咨询已提交\");\n        consultContent.value = \"\";\n        const hRes = await consultationApi.listByUser(userStore.userId);\n        if (hRes.code === 200) history.value = hRes.data || [];\n      } catch (_) {/* 忽略 */}\n      loading.value = false;\n    };\n    onMounted(loadData);\n    const __returned__ = {\n      userStore,\n      doctors,\n      selectedDoctor,\n      consultContent,\n      history,\n      loading,\n      formatTime,\n      loadData,\n      handleSubmit,\n      ref,\n      onMounted,\n      get ElMessage() {\n        return ElMessage;\n      },\n      get doctorApi() {\n        return doctorApi;\n      },\n      get consultationApi() {\n        return consultationApi;\n      },\n      get useUserStore() {\n        return useUserStore;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","onMounted","ElMessage","doctorApi","consultationApi","useUserStore","userStore","doctors","selectedDoctor","consultContent","history","loading","formatTime","t","slice","replace","loadData","dRes","list","code","value","data","hRes","listByUser","userId","handleSubmit","trim","warning","add","doctorId","id","content","success","_"],"sources":["E:/WebDevelopment/STS5workspace/实训文件夹/diabetes-frontend/src/views/patient/DoctorConsult.vue"],"sourcesContent":["<template>\n  <div class=\"doctor-consult\">\n    <div class=\"page-header\">\n      <h3>医师咨询</h3>\n    </div>\n\n    <!-- 医师列表 -->\n    <div class=\"section-title\">选择医师</div>\n    <div class=\"doctor-list\">\n      <div v-for=\"doc in doctors\" :key=\"doc.id\" class=\"doctor-card\" :class=\"{ active: selectedDoctor?.id === doc.id }\" @click=\"selectedDoctor = doc\">\n        <el-avatar :size=\"44\" icon=\"UserFilled\" />\n        <div class=\"doctor-info\">\n          <div class=\"doctor-name\">{{ doc.name }}</div>\n          <div class=\"doctor-meta\">{{ doc.department }} · {{ doc.title }}</div>\n          <div class=\"doctor-good\">{{ doc.goodAt }}</div>\n        </div>\n      </div>\n    </div>\n\n    <!-- 咨询输入 -->\n    <div class=\"consult-input\" v-if=\"selectedDoctor\">\n      <div class=\"section-title\">向 {{ selectedDoctor.name }} 咨询</div>\n      <el-input v-model=\"consultContent\" type=\"textarea\" :rows=\"4\" placeholder=\"请输入您的问题...\" />\n      <el-button type=\"primary\" :loading=\"loading\" @click=\"handleSubmit\" class=\"submit-btn\">提交咨询</el-button>\n    </div>\n\n    <!-- 咨询历史 -->\n    <div class=\"section\">\n      <div class=\"section-title\">咨询历史</div>\n      <div v-for=\"item in history\" :key=\"item.id\" class=\"history-item\">\n        <div class=\"history-header\">\n          <span class=\"history-doctor\">{{ item.doctor_name }}</span>\n          <el-tag size=\"small\" :type=\"item.status === '已回复' ? 'success' : 'warning'\">{{ item.status }}</el-tag>\n        </div>\n        <div class=\"history-question\">问：{{ item.content }}</div>\n        <div v-if=\"item.reply\" class=\"history-answer\">答：{{ item.reply }}</div>\n        <div class=\"history-time\">{{ formatTime(item.created_time) }}</div>\n      </div>\n      <div v-if=\"history.length === 0\" class=\"empty-tip\">暂无咨询记录</div>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, onMounted } from \"vue\";\nimport { ElMessage } from \"element-plus\";\nimport { doctorApi, consultationApi } from \"../../api/index.js\";\nimport { useUserStore } from \"../../store/index.js\";\n\nconst userStore = useUserStore();\nconst doctors = ref([]);\nconst selectedDoctor = ref(null);\nconst consultContent = ref(\"\");\nconst history = ref([]);\nconst loading = ref(false);\n\nconst formatTime = (t) => t ? t.slice(0, 16).replace(\"T\", \" \") : \"\";\n\nconst loadData = async () => {\n  const dRes = await doctorApi.list();\n  if (dRes.code === 200) doctors.value = dRes.data || [];\n  const hRes = await consultationApi.listByUser(userStore.userId);\n  if (hRes.code === 200) history.value = hRes.data || [];\n};\n\nconst handleSubmit = async () => {\n  if (!consultContent.value.trim()) return ElMessage.warning(\"请输入问题\");\n  if (!selectedDoctor.value) return ElMessage.warning(\"请选择医师\");\n  loading.value = true;\n  try {\n    await consultationApi.add({ userId: userStore.userId, doctorId: selectedDoctor.value.id, content: consultContent.value });\n    ElMessage.success(\"咨询已提交\");\n    consultContent.value = \"\";\n    const hRes = await consultationApi.listByUser(userStore.userId);\n    if (hRes.code === 200) history.value = hRes.data || [];\n  } catch (_) { /* 忽略 */ }\n  loading.value = false;\n};\n\nonMounted(loadData);\n</script>\n\n<style scoped>\n.doctor-consult { padding: 16px; max-width: 500px; margin: 0 auto; }\n.page-header h3 { font-size: 20px; margin-bottom: 16px; }\n.section-title { font-size: 15px; font-weight: bold; color: #303133; margin-bottom: 12px; }\n.doctor-list { margin-bottom: 16px; }\n.doctor-card {\n  display: flex; gap: 12px; background: #fff; border-radius: 12px; padding: 14px;\n  margin-bottom: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); cursor: pointer;\n  border: 2px solid transparent; transition: border-color 0.2s;\n}\n.doctor-card.active { border-color: #409eff; }\n.doctor-info { flex: 1; }\n.doctor-name { font-size: 15px; font-weight: bold; }\n.doctor-meta { font-size: 12px; color: #909399; margin: 2px 0; }\n.doctor-good { font-size: 12px; color: #67c23a; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n.consult-input { background: #fff; border-radius: 12px; padding: 16px; margin-bottom: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }\n.submit-btn { width: 100%; margin-top: 12px; border-radius: 20px; }\n.section { background: #fff; border-radius: 12px; padding: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }\n.history-item { padding: 12px 0; border-bottom: 1px solid #f0f0f0; }\n.history-item:last-child { border-bottom: none; }\n.history-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }\n.history-doctor { font-weight: bold; color: #409eff; font-size: 14px; }\n.history-question { font-size: 13px; color: #303133; margin-bottom: 4px; }\n.history-answer { font-size: 13px; color: #67c23a; padding: 8px; background: #f0f9eb; border-radius: 8px; margin-bottom: 4px; }\n.history-time { font-size: 12px; color: #c0c4cc; }\n.empty-tip { text-align: center; padding: 24px; color: #909399; }\n</style>\n"],"mappings":"AA4CA,SAASA,GAAG,EAAEC,SAAS,QAAQ,KAAK;AACpC,SAASC,SAAS,QAAQ,cAAc;AACxC,SAASC,SAAS,EAAEC,eAAe,QAAQ,oBAAoB;AAC/D,SAASC,YAAY,QAAQ,sBAAsB;;;;;;;IAEnD,MAAMC,SAAS,