{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { ref, reactive } from \"vue\";\nimport { useRouter } from \"vue-router\";\nimport { ElMessage } from \"element-plus\";\nimport { userApi } from \"../../api/index.js\";\nexport default {\n  __name: 'Register',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const router = useRouter();\n    const loading = ref(false);\n    const formRef = ref(null);\n    const form = reactive({\n      username: \"\",\n      name: \"\",\n      phone: \"\",\n      age: 30,\n      gender: \"男\",\n      password: \"\",\n      confirmPassword: \"\"\n    });\n    const validatePass = (rule, value, callback) => {\n      if (value !== form.password) {\n        callback(new Error(\"两次输入密码不一致\"));\n      } else {\n        callback();\n      }\n    };\n    const rules = {\n      username: [{\n        required: true,\n        message: \"请输入用户名\",\n        trigger: \"blur\"\n      }],\n      name: [{\n        required: true,\n        message: \"请输入姓名\",\n        trigger: \"blur\"\n      }],\n      phone: [{\n        required: true,\n        message: \"请输入手机号\",\n        trigger: \"blur\"\n      }],\n      password: [{\n        required: true,\n        message: \"请输入密码\",\n        trigger: \"blur\"\n      }, {\n        min: 6,\n        message: \"密码至少6位\",\n        trigger: \"blur\"\n      }],\n      confirmPassword: [{\n        required: true,\n        message: \"请确认密码\",\n        trigger: \"blur\"\n      }, {\n        validator: validatePass,\n        trigger: \"blur\"\n      }]\n    };\n    const handleRegister = async () => {\n      const valid = await formRef.value.validate().catch(() => false);\n      if (!valid) return;\n      loading.value = true;\n      try {\n        const res = await userApi.register({\n          username: form.username,\n          password: form.password,\n          name: form.name,\n          phone: form.phone,\n          age: form.age,\n          gender: form.gender\n        });\n        if (res.code === 200) {\n          ElMessage.success(\"注册成功，请登录\");\n          router.push(\"/login\");\n        } else {\n          ElMessage.error(res.message || \"注册失败\");\n        }\n      } catch (e) {\n        ElMessage.error(\"注册失败\");\n      }\n      loading.value = false;\n    };\n    const __returned__ = {\n      router,\n      loading,\n      formRef,\n      form,\n      validatePass,\n      rules,\n      handleRegister,\n      ref,\n      reactive,\n      get useRouter() {\n        return useRouter;\n      },\n      get ElMessage() {\n        return ElMessage;\n      },\n      get userApi() {\n        return userApi;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","reactive","useRouter","ElMessage","userApi","router","loading","formRef","form","username","name","phone","age","gender","password","confirmPassword","validatePass","rule","value","callback","Error","rules","required","message","trigger","min","validator","handleRegister","valid","validate","catch","res","register","code","success","push","error","e"],"sources":["E:/WebDevelopment/STS5workspace/实训文件夹/diabetes-frontend/src/views/login/Register.vue"],"sourcesContent":["<template>\n  <div class=\"register-page\">\n    <div class=\"register-card\">\n      <div class=\"register-header\">\n        <el-icon :size=\"40\" color=\"#409eff\"><Plus /></el-icon>\n        <h2>注册账号</h2>\n      </div>\n      <el-form ref=\"formRef\" :model=\"form\" :rules=\"rules\" size=\"large\" label-width=\"80px\">\n        <el-form-item label=\"用户名\" prop=\"username\">\n          <el-input v-model=\"form.username\" placeholder=\"请输入用户名\" />\n        </el-form-item>\n        <el-form-item label=\"姓名\" prop=\"name\">\n          <el-input v-model=\"form.name\" placeholder=\"请输入姓名\" />\n        </el-form-item>\n        <el-form-item label=\"手机号\" prop=\"phone\">\n          <el-input v-model=\"form.phone\" placeholder=\"请输入手机号\" maxlength=\"11\" />\n        </el-form-item>\n        <el-row :gutter=\"12\">\n          <el-col :span=\"12\">\n            <el-form-item label=\"年龄\" prop=\"age\">\n              <el-input-number v-model=\"form.age\" :min=\"1\" :max=\"150\" style=\"width: 100%\" />\n            </el-form-item>\n          </el-col>\n          <el-col :span=\"12\">\n            <el-form-item label=\"性别\" prop=\"gender\">\n              <el-select v-model=\"form.gender\" style=\"width: 100%\">\n                <el-option label=\"男\" value=\"男\" />\n                <el-option label=\"女\" value=\"女\" />\n              </el-select>\n            </el-form-item>\n          </el-col>\n        </el-row>\n        <el-form-item label=\"密码\" prop=\"password\">\n          <el-input v-model=\"form.password\" type=\"password\" placeholder=\"请输入密码\" show-password />\n        </el-form-item>\n        <el-form-item label=\"确认密码\" prop=\"confirmPassword\">\n          <el-input v-model=\"form.confirmPassword\" type=\"password\" placeholder=\"请确认密码\" show-password />\n        </el-form-item>\n        <el-button type=\"primary\" size=\"large\" :loading=\"loading\" @click=\"handleRegister\" class=\"register-btn\">\n          注 册\n        </el-button>\n      </el-form>\n      <div class=\"register-footer\">\n        <span>已有账号？</span>\n        <router-link to=\"/login\" class=\"login-link\">去登录</router-link>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, reactive } from \"vue\";\nimport { useRouter } from \"vue-router\";\nimport { ElMessage } from \"element-plus\";\nimport { userApi } from \"../../api/index.js\";\n\nconst router = useRouter();\nconst loading = ref(false);\nconst formRef = ref(null);\n\nconst form = reactive({\n  username: \"\",\n  name: \"\",\n  phone: \"\",\n  age: 30,\n  gender: \"男\",\n  password: \"\",\n  confirmPassword: \"\",\n});\n\nconst validatePass = (rule, value, callback) => {\n  if (value !== form.password) {\n    callback(new Error(\"两次输入密码不一致\"));\n  } else {\n    callback();\n  }\n};\n\nconst rules = {\n  username: [{ required: true, message: \"请输入用户名\", trigger: \"blur\" }],\n  name: [{ required: true, message: \"请输入姓名\", trigger: \"blur\" }],\n  phone: [{ required: true, message: \"请输入手机号\", trigger: \"blur\" }],\n  password: [{ required: true, message: \"请输入密码\", trigger: \"blur\" }, { min: 6, message: \"密码至少6位\", trigger: \"blur\" }],\n  confirmPassword: [{ required: true, message: \"请确认密码\", trigger: \"blur\" }, { validator: validatePass, trigger: \"blur\" }],\n};\n\nconst handleRegister = async () => {\n  const valid = await formRef.value.validate().catch(() => false);\n  if (!valid) return;\n  loading.value = true;\n  try {\n    const res = await userApi.register({\n      username: form.username,\n      password: form.password,\n      name: form.name,\n      phone: form.phone,\n      age: form.age,\n      gender: form.gender,\n    });\n    if (res.code === 200) {\n      ElMessage.success(\"注册成功，请登录\");\n      router.push(\"/login\");\n    } else {\n      ElMessage.error(res.message || \"注册失败\");\n    }\n  } catch (e) {\n    ElMessage.error(\"注册失败\");\n  }\n  loading.value = false;\n};\n</script>\n\n<style scoped>\n.register-page {\n  min-height: 100vh;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n  padding: 20px;\n}\n.register-card {\n  width: 100%;\n  max-width: 420px;\n  background: #fff;\n  border-radius: 16px;\n  padding: 28px 20px;\n  box-shadow: 0 20px 60px rgba(0,0,0,0.3);\n}\n.register-header {\n  text-align: center;\n  margin-bottom: 20px;\n}\n.register-header h2 {\n  font-size: 22px;\n  color: #303133;\n  margin-top: 8px;\n}\n.register-btn {\n  width: 100%;\n  height: 44px;\n  font-size: 16px;\n  border-radius: 22px;\n  margin-top: 8px;\n}\n.register-footer {\n  text-align: center;\n  margin-top: 16px;\n  font-size: 14px;\n  color: #909399;\n}\n.login-link {\n  color: #409eff;\n  text-decoration: none;\n}\n</style>\n"],"mappings":";AAmDA,SAASA,GAAG,EAAEC,QAAQ,QAAQ,KAAK;AACnC,SAASC,SAAS,QAAQ,YAAY;AACtC,SAASC,SAAS,QAAQ,cAAc;AACxC,SAASC,OAAO,QAAQ,oBAAoB;;;;;;;IAE5C,MAAMC,MAAM,GAAGH,SAAS,CAAC,CAAC;IAC1B,MAAMI,OAAO,GAAGN,GAAG,CAAC,KAAK,CAAC;IAC1B,MAAMO,OAAO,GAAGP,GAAG,CAAC,IAAI,CAAC;IAEzB,MAAMQ,IAAI,GAAGP,QAAQ,CAAC;MACpBQ,QAAQ,EAAE,EAAE;MACZC,IAAI,EAAE,EAAE;MACRC,KAAK,EAAE,EAAE;MACTC,GAAG,EAAE,EAAE;MACPC,MAAM,EAAE,GAAG;MACXC,QAAQ,EAAE,EAAE;MACZC,eAAe,EAAE;IACnB,CAAC,CAAC;IAEF,MAAMC,YAAY,GAAGA,CAACC,IAAI,EAAEC,KAAK,EAAEC,QAAQ,KAAK;MAC9C,IAAID,KAAK,KAAKV,IAAI,CAACM,QAAQ,EAAE;QAC3BK,QAAQ,CAAC,IAAIC,KAAK,CAAC,WAAW,CAAC,CAAC;MAClC,CAAC,MAAM;QACLD,QAAQ,CAAC,CAAC;MACZ;IACF,CAAC;IAED,MAAME,KAAK,GAAG;MACZZ,QAAQ,EAAE,CAAC;QAAEa,QAAQ,EAAE,IAAI;QAAEC,OAAO,EAAE,QAAQ;QAAEC,OAAO,EAAE;MAAO,CAAC,CAAC;MAClEd,IAAI,EAAE,CAAC;QAAEY,QAAQ,EAAE,IAAI;QAAEC,OAAO,EAAE,OAAO;QAAEC,OAAO,EAAE;MAAO,CAAC,CAAC;MAC7Db,KAAK,EAAE,CAAC;QAAEW,QAAQ,EAAE,IAAI;QAAEC,OAAO,EAAE,QAAQ;QAAEC,OAAO,EAAE;MAAO,CAAC,CAAC;MAC/DV,QAAQ,EAAE,CAAC;QAAEQ,QAAQ,EAAE,IAAI;QAAEC,OAAO,EAAE,OAAO;QAAEC,OAAO,EAAE;MAAO,CAAC,EAAE;QAAEC,GAAG,EAAE,CAAC;QAAEF,OAAO,EAAE,QAAQ;QAAEC,OAAO,EAAE;MAAO,CAAC,CAAC;MACjHT,eAAe,EAAE,CAAC;QAAEO,QAAQ,EAAE,IAAI;QAAEC,OAAO,EAAE,OAAO;QAAEC,OAAO,EAAE;MAAO,CAAC,EAAE;QAAEE,SAAS,EAAEV,YAAY;QAAEQ,OAAO,EAAE;MAAO,CAAC;IACvH,CAAC;IAED,MAAMG,cAAc,GAAG,MAAAA,CAAA,KAAY;MACjC,MAAMC,KAAK,GAAG,MAAMrB,OAAO,CAACW,KAAK,CAACW,QAAQ,CAAC,CAAC,CAACC,KAAK,CAAC,MAAM,KAAK,CAAC;MAC/D,IAAI,CAACF,KAAK,EAAE;MACZtB,OAAO,CAACY,KAAK,GAAG,IAAI;MACpB,IAAI;QACF,MAAMa,GAAG,GAAG,MAAM3B,OAAO,CAAC4B,QAAQ,CAAC;UACjCvB,QAAQ,EAAED,IAAI,CAACC,QAAQ;UACvBK,QAAQ,EAAEN,IAAI,CAACM,QAAQ;UACvBJ,IAAI,EAAEF,IAAI,CAACE,IAAI;UACfC,KAAK,EAAEH,IAAI,CAACG,KAAK;UACjBC,GAAG,EAAEJ,IAAI,CAACI,GAAG;UACbC,MAAM,EAAEL,IAAI,CAACK;QACf,CAAC,CAAC;QACF,IAAIkB,GAAG,CAACE,IAAI,KAAK,GAAG,EAAE;UACpB9B,SAAS,CAAC+B,OAAO,CAAC,UAAU,CAAC;UAC7B7B,MAAM,CAAC8B,IAAI,CAAC,QAAQ,CAAC;QACvB,CAAC,MAAM;UACLhC