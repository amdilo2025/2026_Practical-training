{"ast":null,"code":"import { onMounted } from \"vue\";\n\n// 确定性生成背景粒子样式（不依赖随机，保证稳定）\nconst BURST_SELECTOR = \"button, .el-button, .nav-item, .quick-item, .action-item, .checkin-item, .article-card, .doctor-card, .cat-tag, .predict-btn, .login-btn, .register-btn, .send-btn, .submit-btn, .history-item, .tab-pane\";\nexport default {\n  __name: 'App',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const particleStyle = n => {\n      const left = (n * 37 + 7) % 100;\n      const size = 3 + n % 4 * 2;\n      const delay = n * 0.9 % 9;\n      const dur = 13 + n % 6 * 3;\n      return {\n        left: left + \"%\",\n        width: size + \"px\",\n        height: size + \"px\",\n        animationDelay: delay + \"s\",\n        animationDuration: dur + \"s\"\n      };\n    };\n\n    // 点击交互元素时爆发粒子（按钮 / 卡片 / 导航等）\n    const BURST_COLORS = [\"#22d3ee\", \"#0ea5e9\", \"#06b6d4\", \"#f59e0b\", \"#ffffff\"];\n    const spawnParticles = (x, y) => {\n      const wrap = document.createElement(\"div\");\n      wrap.className = \"click-burst\";\n      wrap.style.left = x + \"px\";\n      wrap.style.top = y + \"px\";\n      const count = 12;\n      for (let i = 0; i < count; i++) {\n        const p = document.createElement(\"span\");\n        const angle = Math.PI * 2 * i / count + Math.random() * 0.5;\n        const dist = 30 + Math.random() * 50;\n        const color = BURST_COLORS[i % BURST_COLORS.length];\n        p.style.setProperty(\"--dx\", Math.cos(angle) * dist + \"px\");\n        p.style.setProperty(\"--dy\", Math.sin(angle) * dist + \"px\");\n        const sz = 4 + Math.random() * 5;\n        p.style.width = sz + \"px\";\n        p.style.height = sz + \"px\";\n        p.style.background = color;\n        p.style.boxShadow = \"0 0 8px \" + color;\n        wrap.appendChild(p);\n      }\n      document.body.appendChild(wrap);\n      setTimeout(() => wrap.remove(), 700);\n    };\n    onMounted(() => {\n      document.addEventListener(\"click\", e => {\n        const el = e.target.closest && e.target.closest(BURST_SELECTOR);\n        if (el) spawnParticles(e.clientX, e.clientY);\n      });\n    });\n    const __returned__ = {\n      particleStyle,\n      BURST_COLORS,\n      BURST_SELECTOR,\n      spawnParticles,\n      onMounted\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["onMounted","BURST_SELECTOR","particleStyle","n","left","size","delay","dur","width","height","animationDelay","animationDuration","BURST_COLORS","spawnParticles","x","y","wrap","document","createElement","className","style","top","count","i","p","angle","Math","PI","random","dist","color","length","setProperty","cos","sin","sz","background","boxShadow","appendChild","body","setTimeout","remove","addEventListener","e","el","target","closest","clientX","clientY"],"sources":["D:/软件系统实训/diabetes-frontend/src/App.vue"],"sourcesContent":["<template>\n  <div id=\"app-container\">\n    <!-- 全局动态背景层：极光光斑 + 科技网格 + 漂浮粒子 -->\n    <div class=\"bg-fx\" aria-hidden=\"true\">\n      <div class=\"aurora aurora-1\"></div>\n      <div class=\"aurora aurora-2\"></div>\n      <div class=\"aurora aurora-3\"></div>\n      <div class=\"grid-lines\"></div>\n      <div class=\"particles\">\n        <span v-for=\"n in 42\" :key=\"n\" class=\"particle\" :style=\"particleStyle(n)\"></span>\n      </div>\n    </div>\n    <router-view />\n  </div>\n</template>\n\n<script setup>\nimport { onMounted } from \"vue\";\n\n// 确定性生成背景粒子样式（不依赖随机，保证稳定）\nconst particleStyle = (n) => {\n  const left = (n * 37 + 7) % 100;\n  const size = 3 + (n % 4) * 2;\n  const delay = (n * 0.9) % 9;\n  const dur = 13 + (n % 6) * 3;\n  return {\n    left: left + \"%\",\n    width: size + \"px\",\n    height: size + \"px\",\n    animationDelay: delay + \"s\",\n    animationDuration: dur + \"s\",\n  };\n};\n\n// 点击交互元素时爆发粒子（按钮 / 卡片 / 导航等）\nconst BURST_COLORS = [\"#22d3ee\", \"#0ea5e9\", \"#06b6d4\", \"#f59e0b\", \"#ffffff\"];\nconst BURST_SELECTOR =\n  \"button, .el-button, .nav-item, .quick-item, .action-item, .checkin-item, .article-card, .doctor-card, .cat-tag, .predict-btn, .login-btn, .register-btn, .send-btn, .submit-btn, .history-item, .tab-pane\";\n\nconst spawnParticles = (x, y) => {\n  const wrap = document.createElement(\"div\");\n  wrap.className = \"click-burst\";\n  wrap.style.left = x + \"px\";\n  wrap.style.top = y + \"px\";\n  const count = 12;\n  for (let i = 0; i < count; i++) {\n    const p = document.createElement(\"span\");\n    const angle = (Math.PI * 2 * i) / count + Math.random() * 0.5;\n    const dist = 30 + Math.random() * 50;\n    const color = BURST_COLORS[i % BURST_COLORS.length];\n    p.style.setProperty(\"--dx\", Math.cos(angle) * dist + \"px\");\n    p.style.setProperty(\"--dy\", Math.sin(angle) * dist + \"px\");\n    const sz = 4 + Math.random() * 5;\n    p.style.width = sz + \"px\";\n    p.style.height = sz + \"px\";\n    p.style.background = color;\n    p.style.boxShadow = \"0 0 8px \" + color;\n    wrap.appendChild(p);\n  }\n  document.body.appendChild(wrap);\n  setTimeout(() => wrap.remove(), 700);\n};\n\nonMounted(() => {\n  document.addEventListener(\"click\", (e) => {\n    const el = e.target.closest && e.target.closest(BURST_SELECTOR);\n    if (el) spawnParticles(e.clientX, e.clientY);\n  });\n});\n</script>\n\n<style>\nhtml, body, #app, #app-container {\n  height: 100%;\n  width: 100%;\n  margin: 0;\n  padding: 0;\n}\n#app-container { position: relative; }\n\n/* ===== 动态背景层 ===== */\n.bg-fx {\n  position: fixed;\n  inset: 0;\n  z-index: 0;\n  overflow: hidden;\n  pointer-events: none;\n}\n\n/* 极光光斑 */\n.aurora {\n  position: absolute;\n  border-radius: 50%;\n  filter: blur(70px);\n  opacity: 0.55;\n  animation: auroraMove 24s ease-in-out infinite;\n}\n.aurora-1 {\n  width: 500px; height: 500px;\n  top: -140px; left: -120px;\n  background: radial-gradient(circle, rgba(34, 211, 238, 0.55), transparent 70%);\n}\n.aurora-2 {\n  width: 440px; height: 440px;\n  bottom: -120px; right: -90px;\n  background: radial-gradient(circle, rgba(14, 165, 233, 0.5), transparent 70%);\n  animation-delay: -8s;\n}\n.aurora-3 {\n  width: 380px; height: 380px;\n  top: 38%; left: 45%;\n  background: radial-gradient(circle, rgba(6, 182, 212, 0.4), transparent 70%);\n  animation-delay: -16s;\n}\n\n/* 科技网格线 */\n.grid-lines {\n  position: absolute;\n  inset: 0;\n  background-image:\n    linear-gradient(rgba(34, 211, 238, 0.06) 1px, transparent 1px),\n    linear-gradient(90deg, rgba(34, 211, 238, 0.06) 1px, transparent 1px);\n  background-size: 42px 42px;\n  -webkit-mask-image: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.7), transparent 75%);\n  mask-image: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.7), transparent 75%);\n}\n\n/* 漂浮粒子 */\n.particles { position: absolute; inset: 0; }\n.particle {\n  position: absolute;\n  bottom: -12px;\n  border-radius: 50%;\n  background: radial-gradient(circle, rgba(34, 211, 238, 0.95), rgba(34, 211, 238, 0.15));\n  box-shadow: 0 0 10px rgba(34, 211, 238, 0.7);\n  animation: particleDrift linear infinite;\n}\n\n@keyframes auroraMove {\n  0%   { transform: translate(0, 0) scale(1); }\n  33%  { transform: translate(44px, -32px) scale(1.12); }\n  66%  { transform: translate(-32px, 42px) scale(0.94); }\n  100% { transform: translate(0, 0) scale(1); }\n}\n@keyframes particleDrift {\n  0%   { transform: translateY(0) translateX(0); opacity: 0; }\n  10%  { opacity: 0.85; }\n  90%  { opacity: 0.85; }\n  100% { transform: translateY(-106vh) translateX(42px); opacity: 0; }\n}\n\n/* ===== 点击粒子爆发 ===== */\n.click-burst {\n  position: fixed;\n  z-index: 9999;\n  pointer-events: none;\n}\n.click-burst span {\n  position: absolute;\n  border-radius: 50%;\n  transform: translate(-50%, -50%);\n  animation: clickBurst 0.65s cubic-bezier(0.16, 1, 0.3, 1) forwards;\n}\n@keyframes clickBurst {\n  0%   { transform: translate(-50%, -50%) translate(0, 0) scale(1); opacity: 1; }\n  100% { transform: translate(-50%, -50%) translate(var(--dx), var(--dy)) scale(0.2); opacity: 0; }\n}\n</style>\n"],"mappings":"AAiBA,SAASA,SAAS,QAAQ,KAAK;;AAE/B;AAiBA,MAAMC,cAAc,GAClB,2MAA2M;;;;;;;IAjB7M,MAAMC,aAAa,GAAIC,CAAC,IAAK;MAC3B,MAAMC,IAAI,GAAG,CAACD,CAAC,GAAG,EAAE,GAAG,CAAC,IAAI,GAAG;MAC/B,MAAME,IAAI,GAAG,CAAC,GAAIF,CAAC,GAAG,CAAC,GAAI,CAAC;MAC5B,MAAMG,KAAK,GAAIH,CAAC,GAAG,GAAG,GAAI,CAAC;MAC3B,MAAMI,GAAG,GAAG,EAAE,GAAIJ,CAAC,GAAG,CAAC,GAAI,CAAC;MAC5B,OAAO;QACLC,IAAI,EAAEA,IAAI,GAAG,GAAG;QAChBI,KAAK,EAAEH,IAAI,GAAG,IAAI;QAClBI,MAAM,EAAEJ,IAAI,GAAG,IAAI;QACnBK,cAAc,EAAEJ,KAAK,GAAG,GAAG;QAC3BK,iBAAiB,EAAEJ,GAAG,GAAG;MAC3B,CAAC;IACH,CAAC;;IAED;IACA,MAAMK,YAAY,GAAG,CAAC,SAAS,EAAE,SAAS,EAAE,SAAS,EAAE,SAAS,EAAE,SAAS,CAAC;IAI5E,MAAMC,cAAc,GAAGA,CAACC,CAAC,EAAEC,CAAC,KAAK;MAC/B,MAAMC,IAAI,GAAGC,QAAQ,CAACC,aAAa,CAAC,KAAK,CAAC;MAC1CF,IAAI,CAACG,SAAS,GAAG,aAAa;MAC9BH,IAAI,CAACI,KAAK,CAAChB,IAAI,GAAGU,CAAC,GAAG,IAAI;MAC1BE,IAAI,CAACI,KAAK,CAACC,GAAG,GAAGN,CAAC,GAAG,IAAI;MACzB,MAAMO,KAAK,GAAG,EAAE;MAChB,KAAK,IAAIC,CAAC,GAAG,CAAC,EAAEA,CAAC,GAAGD,KAAK,EAAEC,CAAC,EAAE,EAAE;QAC9B,MAAMC,CAAC,GAAGP,QAAQ,CAACC,aAAa,CAAC,MAAM,CAAC;QACxC,MAAMO,KAAK,GAAIC,IAAI,CAACC,EAAE,GAAG,CAAC,GAAGJ,CAAC,GAAID,KAAK,GAAGI,IAAI,CAACE,MAAM,CAAC,CAAC,GAAG,GAAG;QAC7D,MAAMC,IAAI,GAAG,EAAE,GAAGH,IAAI,CAACE,MAAM,CAAC,CAAC,GAAG,EAAE;QACpC,MAAME,KAAK,GAAGlB,YAAY,CAACW,CAAC,GAAGX,YAAY,CAACmB,MAAM,CAAC;QACnDP,CAAC,CAACJ,KAAK,CAACY,WAAW,CAAC,MAAM,EAAEN,IAAI,CAACO,GAAG,CAACR,KAAK,CAAC,GAAGI,IAAI,GAAG,IAAI,CAAC;QAC1DL,CAAC,CAACJ,KAAK,CAACY,WAAW,CAAC,MAAM,EAAEN,IAAI,CAACQ,GAAG,CAACT,KAAK,CAAC,GAAGI,IAAI,GAAG,IAAI,CAAC;QAC1D,MAAMM,EAAE,GAAG,CAAC,GAAGT,IAAI,CAACE,MAAM,CAAC,CAAC,GAAG,CAAC;QAChCJ,CAAC,CAACJ,KAAK,CAACZ,KAAK,GAAG2B,EAAE,GAAG,IAAI;QACzBX,CAAC,CAACJ,KAAK,CAACX,MAAM,GAAG0B,EAAE,GAAG,IAAI;QAC1BX,CAAC,CAACJ,KAAK,CAACgB,UAAU,GAAGN,KAAK;QAC1BN,CAAC,CAACJ,KAAK,CAACiB,SAAS,GAAG,UAAU,GAAGP,KAAK;QACtCd,IAAI,CAACsB,WAAW,CAACd,CAAC,CAAC;MACrB;MACAP,QAAQ,CAACsB,IAAI,CAACD,WAA