{"ast":null,"code":"import { ref, onMounted } from \"vue\";\nimport { useRoute } from \"vue-router\";\nimport { articleApi } from \"../../api/index.js\";\nexport default {\n  __name: 'ArticleDetail',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const route = useRoute();\n    const article = ref(null);\n    const formatTime = t => t ? t.slice(0, 10) : \"\";\n    onMounted(async () => {\n      const res = await articleApi.getById(route.params.id);\n      if (res.code === 200) article.value = res.data;\n    });\n    const __returned__ = {\n      route,\n      article,\n      formatTime,\n      ref,\n      onMounted,\n      get useRoute() {\n        return useRoute;\n      },\n      get articleApi() {\n        return articleApi;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","onMounted","useRoute","articleApi","route","article","formatTime","t","slice","res","getById","params","id","code","value","data"],"sources":["E:/WebDevelopment/STS5workspace/实训文件夹/diabetes-frontend/src/views/patient/ArticleDetail.vue"],"sourcesContent":["<template>\n  <div class=\"article-detail\">\n    <div class=\"detail-header\">\n      <el-button text @click=\"$router.back()\" class=\"back-btn\">\n        <el-icon><ArrowLeft /></el-icon> 返回\n      </el-button>\n    </div>\n\n    <div v-if=\"article\" class=\"detail-content anim-fade-up\">\n      <div class=\"detail-cover\" :style=\"{ background: `linear-gradient(135deg, #2b6cb0, #1a365d)` }\">\n        <span class=\"detail-category-tag\">{{ article.category }}</span>\n      </div>\n      <div class=\"detail-body-wrap\">\n        <h1 class=\"detail-title\">{{ article.title }}</h1>\n        <div class=\"detail-meta\">\n          <span class=\"meta-author\">{{ article.author }}</span>\n          <span class=\"meta-divider\">·</span>\n          <span>{{ formatTime(article.createdTime) }}</span>\n          <span class=\"meta-divider\">·</span>\n          <span>{{ article.views }} 次阅读</span>\n        </div>\n        <div class=\"detail-body\" v-html=\"article.content\"></div>\n      </div>\n    </div>\n    <div v-else class=\"loading-state\">\n      <div class=\"skeleton\" style=\"height:200px;margin-bottom:16px\"></div>\n      <div class=\"skeleton\" style=\"height:24px;width:70%;margin-bottom:12px\"></div>\n      <div class=\"skeleton\" style=\"height:16px;margin-bottom:8px\"></div>\n      <div class=\"skeleton\" style=\"height:16px;width:85%;margin-bottom:8px\"></div>\n      <div class=\"skeleton\" style=\"height:16px;width:60%\"></div>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, onMounted } from \"vue\";\nimport { useRoute } from \"vue-router\";\nimport { articleApi } from \"../../api/index.js\";\n\nconst route = useRoute();\nconst article = ref(null);\n\nconst formatTime = (t) => t ? t.slice(0, 10) : \"\";\n\nonMounted(async () => {\n  const res = await articleApi.getById(route.params.id);\n  if (res.code === 200) article.value = res.data;\n});\n</script>\n\n<style scoped>\n.article-detail { padding-bottom: 24px; max-width: 500px; margin: 0 auto; }\n.detail-header {\n  position: sticky;\n  top: 0;\n  background: #fff;\n  z-index: 10;\n  padding: 8px 16px;\n  border-bottom: 1px solid #edf2f7;\n}\n.back-btn { color: #4a5568; font-size: 14px; }\n.detail-cover {\n  height: 180px;\n  display: flex;\n  align-items: flex-start;\n  justify-content: flex-end;\n  padding: 16px;\n}\n.detail-category-tag {\n  background: rgba(255,255,255,0.9);\n  backdrop-filter: blur(4px);\n  padding: 6px 16px;\n  border-radius: 16px;\n  font-size: 13px;\n  font-weight: 600;\n  color: #2b6cb0;\n}\n.detail-body-wrap { padding: 20px 16px; }\n.detail-title { font-size: 22px; font-weight: 700; line-height: 1.35; margin-bottom: 12px; color: #1a202c; }\n.detail-meta { display: flex; align-items: center; gap: 6px; font-size: 13px; color: #a0aec0; margin-bottom: 20px; }\n.meta-divider { color: #e2e8f0; }\n.detail-body { font-size: 15px; line-height: 1.8; color: #2d3748; }\n.detail-body img { max-width: 100%; border-radius: 10px; margin: 16px 0; }\n.detail-body h3 { font-size: 18px; margin: 20px 0 10px; color: #1a202c; }\n.detail-body p { margin-bottom: 12px; }\n.loading-state { padding: 20px 16px; }\n</style>\n"],"mappings":"AAmCA,SAASA,GAAG,EAAEC,SAAS,QAAQ,KAAK;AACpC,SAASC,QAAQ,QAAQ,YAAY;AACrC,SAASC,UAAU,QAAQ,oBAAoB;;;;;;;IAE/C,MAAMC,KAAK,GAAGF,QAAQ,CAAC,CAAC;IACxB,MAAMG,OAAO,GAAGL,GAAG,CAAC,IAAI,CAAC;IAEzB,MAAMM,UAAU,GAAIC,CAAC,IAAKA,CAAC,GAAGA,CAAC,CAACC,KAAK,CAAC,CAAC,EAAE,EAAE,CAAC,GAAG,EAAE;IAEjDP,SAAS,CAAC,YAAY;MACpB,MAAMQ,GAAG,GAAG,MAAMN,UAAU,CAACO,OAAO,CAACN,KAAK,CAACO,MAAM,CAACC,EAAE,CAAC;MACrD,IAAIH,GAAG,CAACI,IAAI,KAAK,GAAG,EAAER,OAAO,CAACS,KAAK,GAAGL,GAAG,CAACM,IAAI;IAChD,CAAC,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}