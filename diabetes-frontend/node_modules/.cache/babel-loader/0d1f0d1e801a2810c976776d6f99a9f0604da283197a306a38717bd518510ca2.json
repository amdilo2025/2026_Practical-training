{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { ref, reactive, onMounted } from \"vue\";\nimport { useRouter } from \"vue-router\";\nimport { ElMessage, ElMessageBox } from \"element-plus\";\nimport { userApi } from \"../../api/index.js\";\nimport { useUserStore } from \"../../store/index.js\";\nexport default {\n  __name: 'PersonalCenter',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const router = useRouter();\n    const userStore = useUserStore();\n    const userInfo = ref({});\n    const editVisible = ref(false);\n    const pwdVisible = ref(false);\n    const editForm = reactive({});\n    const pwdForm = reactive({\n      oldPassword: \"\",\n      newPassword: \"\",\n      confirm: \"\"\n    });\n    const pwdRules = {\n      oldPassword: [{\n        required: true,\n        message: \"请输入原密码\",\n        trigger: \"blur\"\n      }],\n      newPassword: [{\n        required: true,\n        message: \"请输入新密码\",\n        trigger: \"blur\"\n      }, {\n        min: 6,\n        message: \"至少6位\",\n        trigger: \"blur\"\n      }],\n      confirm: [{\n        required: true,\n        message: \"请确认密码\",\n        trigger: \"blur\"\n      }, {\n        validator: (rule, val, cb) => val === pwdForm.newPassword ? cb() : cb(new Error(\"密码不一致\")),\n        trigger: \"blur\"\n      }]\n    };\n    const loadInfo = async () => {\n      const res = await userApi.getProfile(userStore.userId);\n      if (res.code === 200) {\n        userInfo.value = res.data;\n        Object.assign(editForm, res.data);\n      }\n    };\n    const handleEdit = async () => {\n      await userApi.updateProfile(editForm);\n      ElMessage.success(\"保存成功\");\n      editVisible.value = false;\n      loadInfo();\n    };\n    const handlePwd = async () => {\n      await userApi.changePassword({\n        userId: userStore.userId,\n        oldPassword: pwdForm.oldPassword,\n        newPassword: pwdForm.newPassword\n      });\n      ElMessage.success(\"密码修改成功\");\n      pwdVisible.value = false;\n    };\n    const handleLogout = async () => {\n      await ElMessageBox.confirm(\"确定退出登录？\", \"提示\", {\n        type: \"warning\"\n      });\n      userStore.logout();\n      router.push(\"/login\");\n    };\n    onMounted(loadInfo);\n    const __returned__ = {\n      router,\n      userStore,\n      userInfo,\n      editVisible,\n      pwdVisible,\n      editForm,\n      pwdForm,\n      pwdRules,\n      loadInfo,\n      handleEdit,\n      handlePwd,\n      handleLogout,\n      ref,\n      reactive,\n      onMounted,\n      get useRouter() {\n        return useRouter;\n      },\n      get ElMessage() {\n        return ElMessage;\n      },\n      get ElMessageBox() {\n        return ElMessageBox;\n      },\n      get userApi() {\n        return userApi;\n      },\n      get useUserStore() {\n        return useUserStore;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","reactive","onMounted","useRouter","ElMessage","ElMessageBox","userApi","useUserStore","router","userStore","userInfo","editVisible","pwdVisible","editForm","pwdForm","oldPassword","newPassword","confirm","pwdRules","required","message","trigger","min","validator","rule","val","cb","Error","loadInfo","res","getProfile","userId","code","value","data","Object","assign","handleEdit","updateProfile","success","handlePwd","changePassword","handleLogout","type","logout","push"],"sources":["E:/WebDevelopment/STS5workspace/实训文件夹/diabetes-frontend/src/views/patient/PersonalCenter.vue"],"sourcesContent":["<template>\n  <div class=\"personal-center\">\n    <!-- 用户头像信息 -->\n    <div class=\"profile-header\">\n      <el-avatar :size=\"72\" icon=\"User\" />\n      <h3>{{ userInfo.name || '用户' }}</h3>\n      <p>{{ userInfo.username }}</p>\n    </div>\n\n    <!-- 个人信息 -->\n    <el-card shadow=\"never\" class=\"info-card\">\n      <template #header><span style=\"font-weight: bold\">个人信息</span></template>\n      <el-descriptions :column=\"1\" border size=\"small\">\n        <el-descriptions-item label=\"姓名\">{{ userInfo.name }}</el-descriptions-item>\n        <el-descriptions-item label=\"手机号\">{{ userInfo.phone }}</el-descriptions-item>\n        <el-descriptions-item label=\"年龄\">{{ userInfo.age }}岁</el-descriptions-item>\n        <el-descriptions-item label=\"性别\">{{ userInfo.gender }}</el-descriptions-item>\n        <el-descriptions-item label=\"身高\">{{ userInfo.height || '-' }} cm</el-descriptions-item>\n        <el-descriptions-item label=\"体重\">{{ userInfo.weight || '-' }} kg</el-descriptions-item>\n        <el-descriptions-item label=\"糖尿病类型\">{{ userInfo.diabetesType || '未填写' }}</el-descriptions-item>\n      </el-descriptions>\n    </el-card>\n\n    <!-- 操作按钮 -->\n    <div class=\"action-list\">\n      <div class=\"action-item\" @click=\"editVisible = true\">\n        <el-icon><Edit /></el-icon><span>编辑资料</span>\n        <el-icon><ArrowRight /></el-icon>\n      </div>\n      <div class=\"action-item\" @click=\"pwdVisible = true\">\n        <el-icon><Lock /></el-icon><span>修改密码</span>\n        <el-icon><ArrowRight /></el-icon>\n      </div>\n      <div class=\"action-item\" @click=\"handleLogout\">\n        <el-icon style=\"color:#f56c6c\"><SwitchButton /></el-icon>\n        <span style=\"color:#f56c6c\">退出登录</span>\n        <el-icon><ArrowRight /></el-icon>\n      </div>\n    </div>\n\n    <!-- 编辑资料对话框 -->\n    <el-dialog v-model=\"editVisible\" title=\"编辑资料\" width=\"95%\" top=\"5vh\">\n      <el-form ref=\"editFormRef\" :model=\"editForm\" label-width=\"80px\">\n        <el-form-item label=\"姓名\"><el-input v-model=\"editForm.name\" /></el-form-item>\n        <el-form-item label=\"手机号\"><el-input v-model=\"editForm.phone\" /></el-form-item>\n        <el-row :gutter=\"12\">\n          <el-col :span=\"12\"><el-form-item label=\"年龄\"><el-input-number v-model=\"editForm.age\" :min=\"1\" :max=\"150\" style=\"width:100%\" /></el-form-item></el-col>\n          <el-col :span=\"12\"><el-form-item label=\"性别\"><el-select v-model=\"editForm.gender\" style=\"width:100%\"><el-option label=\"男\" value=\"男\" /><el-option label=\"女\" value=\"女\" /></el-select></el-form-item></el-col>\n        </el-row>\n        <el-row :gutter=\"12\">\n          <el-col :span=\"12\"><el-form-item label=\"身高(cm)\"><el-input-number v-model=\"editForm.height\" :min=\"50\" :max=\"250\" :step=\"0.5\" style=\"width:100%\" /></el-form-item></el-col>\n          <el-col :span=\"12\"><el-form-item label=\"体重(kg)\"><el-input-number v-model=\"editForm.weight\" :min=\"20\" :max=\"300\" :step=\"0.5\" style=\"width:100%\" /></el-form-item></el-col>\n        </el-row>\n        <el-form-item label=\"糖尿病类型\"><el-select v-model=\"editForm.diabetesType\" style=\"width:100%\"><el-option label=\"1型\" value=\"1型\" /><el-option label=\"2型\" value=\"2型\" /><el-option label=\"妊娠期\" value=\"妊娠期\" /><el-option label=\"无\" value=\"\" /></el-select></el-form-item>\n      </el-form>\n      <template #footer>\n        <el-button @click=\"editVisible = false\">取消</el-button>\n        <el-button type=\"primary\" @click=\"handleEdit\">保存</el-button>\n      </template>\n    </el-dialog>\n\n    <!-- 修改密码对话框 -->\n    <el-dialog v-model=\"pwdVisible\" title=\"修改密码\" width=\"95%\" top=\"10vh\">\n      <el-form ref=\"pwdFormRef\" :model=\"pwdForm\" :rules=\"pwdRules\" label-width=\"100px\">\n        <el-form-item label=\"原密码\" prop=\"oldPassword\"><el-input v-model=\"pwdForm.oldPassword\" type=\"password\" show-password /></el-form-item>\n        <el-form-item label=\"新密码\" prop=\"newPassword\"><el-input v-model=\"pwdForm.newPassword\" type=\"password\" show-password /></el-form-item>\n        <el-form-item label=\"确认密码\" prop=\"confirm\"><el-input v-model=\"pwdForm.confirm\" type=\"password\" show-password /></el-form-item>\n      </el-form>\n      <template #footer>\n        <el-button @click=\"pwdVisible = false\">取消</el-button>\n        <el-button type=\"primary\" @click=\"handlePwd\">确认修改</el-button>\n      </template>\n    </el-dialog>\n  </div>\n</template>\n\n<script setup>\nimport { ref, reactive, onMounted } from \"vue\";\nimport { useRouter } from \"vue-router\";\nimport { ElMessage, ElMessageBox } from \"element-plus\";\nimport { userApi } from \"../../api/index.js\";\nimport { useUserStore } from \"../../store/index.js\";\n\nconst router = useRouter();\nconst userStore = useUserStore();\n\nconst userInfo = ref({});\nconst editVisible = ref(false);\nconst pwdVisible = ref(false);\n\nconst editForm = reactive({});\nconst pwdForm = reactive({ oldPassword: \"\", newPassword: \"\", confirm: \"\" });\nconst pwdRules = {\n  oldPassword: [{ required: true, message: \"请输入原密码\", trigger: \"blur\" }],\n  newPassword: [{ required: true, message: \"请输入新密码\", trigger: \"blur\" }, { min: 6, message: \"至少6位\", trigger: \"blur\" }],\n  confirm: [{ required: true, message: \"请确认密码\", trigger: \"blur\" }, { validator: (rule, val, cb) => val === pwdForm.newPassword ? cb() : cb(new Error(\"密码不一致\")), trigger: \"blur\" }],\n};\n\nconst loadInfo = async () => {\n  const res = await userApi.getProfile(userStore.userId);\n  if (res.code === 200) {\n    userInfo.value = res.data;\n    Object.assign(editForm, res.data);\n  }\n};\n\nconst handleEdit = async () => {\n  await userApi.updateProfile(editForm);\n  ElMessage.success(\"保存成功\");\n  editVisible.value = false;\n  loadInfo();\n};\n\nconst handlePwd = async () => {\n  await userApi.changePassword({ userId: userStore.userId, oldPassword: pwdForm.oldPassword, newPassword: pwdForm.newPassword });\n  ElMessage.success(\"密码修改成功\");\n  pwdVisible.value = false;\n};\n\nconst handleLogout = async () => {\n  await ElMessageBox.confirm(\"确定退出登录？\", \"提示\", { type: \"warning\" });\n  userStore.logout();\n  router.push(\"/login\");\n};\n\nonMounted(loadInfo);\n</script>\n\n<style scoped>\n.personal-center { padding: 16px; max-width: 500px; margin: 0 auto; }\n.profile-header { text-align: center; padding: 24px 0; }\n.profile-header h3 { font-size: 20px; margin-top: 12px; }\n.profile-header p { font-size: 14px; color: #909399; margin-top: 4px; }\n.info-card { margin-bottom: 16px; }\n.action-list { background: #fff; border-radius: 12px; overflow: hidden; }\n.action-item { display: flex; align-items: center; gap: 10px; padding: 16px; border-bottom: 1px solid #f0f0f0; cursor: pointer; }\n.action-item:last-child { border-bottom: none; }\n.action-item span { flex: 1; font-size: 15px; }\n</style>\n"],"mappings":";AA6EA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,SAAS,QAAQ,KAAK;AAC9C,SAASC,SAAS,QAAQ,YAAY;AACtC,SAASC,SAAS,EAAEC,YAAY,QAAQ,cAAc;AACtD,SAASC,OAAO,QAAQ,oBAAoB;AAC5C,SAASC,YAAY,QAAQ,sBAAsB;;;;;;;IAEnD,MAAMC,MAAM,GAAGL,SAAS,CAAC,CAAC;IAC1B,MAAMM,SAAS,GAAGF,YAAY,CAAC,CAAC;IAEhC,MAAMG,QAAQ,GAAGV,GAAG,CAAC,CAAC,CAAC,CAAC;IACxB,MAAMW,WAAW,GAAGX,GAAG,CAAC,KAAK,CAAC;IAC9B,MAAMY,UAAU,GAAGZ,GAAG,CAAC,KAAK,CAAC;IAE7B,MAAMa,QAAQ,GAAGZ,QAAQ,CAAC,CAAC,CAAC,CAAC;IAC7B,MAAMa,OAAO,GAAGb,QAAQ,CAAC;MAAEc,WAAW,EAAE,EAAE;MAAEC,WAAW,EAAE,EAAE;MAAEC,OAAO,EAAE;IAAG,CAAC,CAAC;IAC3E,MAAMC,QAAQ,GAAG;MACfH,WAAW,EAAE,CAAC;QAAEI,QAAQ,EAAE,IAAI;QAAEC,OAAO,EAAE,QAAQ;QAAEC,OAAO,EAAE;MAAO,CAAC,CAAC;MACrEL,WAAW,EAAE,CAAC;QAAEG,QAAQ,EAAE,IAAI;QAAEC,OAAO,EAAE,QAAQ;QAAEC,OAAO,EAAE;MAAO,CAAC,EAAE;QAAEC,GAAG,EAAE,CAAC;QAAEF,OAAO,EAAE,MAAM;QAAEC,OAAO,EAAE;MAAO,CAAC,CAAC;MACnHJ,OAAO,EAAE,CAAC;QAAEE,QAAQ,EAAE,IAAI;QAAEC,OAAO,EAAE,OAAO;QAAEC,OAAO,EAAE;MAAO,CAAC,EAAE;QAAEE,SAAS,EAAEA,CAACC,IAAI,EAAEC,GAAG,EAAEC,EAAE,KAAKD,GAAG,KAAKX,OAAO,CAACE,WAAW,GAAGU,EAAE,CAAC,CAAC,GAAGA,EAAE,CAAC,IAAIC,KAAK,CAAC,OAAO,CAAC,CAAC;QAAEN,OAAO,EAAE;MAAO,CAAC;IACjL,CAAC;IAED,MAAMO,QAAQ,GAAG,MAAAA,CAAA,KAAY;MAC3B,MAAMC,GAAG,GAAG,MAAMvB,OAAO,CAACwB,UAAU,CAACrB,SAAS,CAACsB,MAAM,CAAC;MACtD,IAAIF,GAAG,CAACG,IAAI,KAAK,GAAG,EAAE;QACpBtB,QAAQ,CAACuB,KAAK,GAAGJ,GAAG,CAACK,IAAI;QACzBC,MAAM,CAACC,MAAM,CAACvB,QAAQ,EAAEgB,GAAG,CAACK,IAAI,CAAC;MACnC;IACF,CAAC;IAED,MAAMG,UAAU,GAAG,MAAAA,CAAA,