{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { ref, nextTick } from \"vue\";\nimport { chatApi } from \"../../api/index.js\";\nimport { useUserStore } from \"../../store/index.js\";\nexport default {\n  __name: 'SmartAssistant',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const userStore = useUserStore();\n    const messages = ref([]);\n    const inputMsg = ref(\"\");\n    const loading = ref(false);\n    const msgRef = ref(null);\n    const quickQuestions = [\"糖尿病饮食需要注意什么？\", \"适合糖尿病患者的运动有哪些？\", \"血糖正常值范围是多少？\", \"糖尿病可以吃水果吗？\"];\n    const sendMessage = async text => {\n      const msg = text || inputMsg.value;\n      if (!msg.trim()) return;\n      inputMsg.value = \"\";\n      loading.value = true;\n      messages.value.push({\n        role: \"user\",\n        content: msg\n      });\n      scrollToBottom();\n      try {\n        const res = await chatApi.send({\n          userId: userStore.userId,\n          query: msg,\n          sessionId: \"\"\n        });\n        if (res.code === 200) {\n          messages.value.push({\n            role: \"ai\",\n            content: res.data.reply\n          });\n        }\n      } catch (e) {\n        messages.value.push({\n          role: \"ai\",\n          content: \"抱歉，我暂时无法回答，请稍后再试。\"\n        });\n      }\n      loading.value = false;\n      scrollToBottom();\n    };\n    const scrollToBottom = async () => {\n      await nextTick();\n      if (msgRef.value) {\n        msgRef.value.scrollTop = msgRef.value.scrollHeight;\n      }\n    };\n    const __returned__ = {\n      userStore,\n      messages,\n      inputMsg,\n      loading,\n      msgRef,\n      quickQuestions,\n      sendMessage,\n      scrollToBottom,\n      ref,\n      nextTick,\n      get chatApi() {\n        return chatApi;\n      },\n      get useUserStore() {\n        return useUserStore;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","nextTick","chatApi","useUserStore","userStore","messages","inputMsg","loading","msgRef","quickQuestions","sendMessage","text","msg","value","trim","push","role","content","scrollToBottom","res","send","userId","query","sessionId","code","data","reply","e","scrollTop","scrollHeight"],"sources":["E:/WebDevelopment/STS5workspace/实训文件夹/diabetes-frontend/src/views/patient/SmartAssistant.vue"],"sourcesContent":["<template>\n  <div class=\"smart-assistant\">\n    <div class=\"chat-header\">\n      <el-icon :size=\"28\" color=\"#409eff\"><MagicStick /></el-icon>\n      <h3>智能助手</h3>\n      <span class=\"ai-tag\">AI</span>\n    </div>\n\n    <!-- 对话区域 -->\n    <div class=\"chat-messages\" ref=\"msgRef\">\n      <div v-for=\"(msg, i) in messages\" :key=\"i\" class=\"msg-item\" :class=\"msg.role\">\n        <div class=\"msg-avatar\">\n          <el-avatar :size=\"36\" :icon=\"msg.role === 'user' ? 'User' : 'MagicStick'\" :style=\"msg.role === 'ai' ? 'background:#ecf5ff;color:#409eff' : ''\" />\n        </div>\n        <div class=\"msg-content\">{{ msg.content }}</div>\n      </div>\n      <div v-if=\"loading\" class=\"msg-item ai\">\n        <div class=\"msg-avatar\"><el-avatar :size=\"36\" icon=\"MagicStick\" style=\"background:#ecf5ff;color:#409eff\" /></div>\n        <div class=\"msg-content thinking\">思考中...</div>\n      </div>\n      <div v-if=\"messages.length === 0\" class=\"welcome-tip\">\n        <el-icon :size=\"48\" color=\"#c0c4cc\"><MagicStick /></el-icon>\n        <h4>您好！我是您的糖尿病智能助手</h4>\n        <p>您可以向我咨询糖尿病相关问题</p>\n      </div>\n    </div>\n\n    <!-- 快捷问题 -->\n    <div v-if=\"messages.length === 0\" class=\"quick-questions\">\n      <el-tag v-for=\"q in quickQuestions\" :key=\"q\" @click=\"sendMessage(q)\" class=\"q-tag\">{{ q }}</el-tag>\n    </div>\n\n    <!-- 输入框 -->\n    <div class=\"chat-input\">\n      <el-input v-model=\"inputMsg\" placeholder=\"请输入您的问题...\" @keyup.enter=\"sendMessage\" :disabled=\"loading\">\n        <template #append>\n          <el-button @click=\"sendMessage\" :disabled=\"loading || !inputMsg.trim()\">\n            <el-icon><Promotion /></el-icon>\n          </el-button>\n        </template>\n      </el-input>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, nextTick } from \"vue\";\nimport { chatApi } from \"../../api/index.js\";\nimport { useUserStore } from \"../../store/index.js\";\n\nconst userStore = useUserStore();\nconst messages = ref([]);\nconst inputMsg = ref(\"\");\nconst loading = ref(false);\nconst msgRef = ref(null);\n\nconst quickQuestions = [\n  \"糖尿病饮食需要注意什么？\",\n  \"适合糖尿病患者的运动有哪些？\",\n  \"血糖正常值范围是多少？\",\n  \"糖尿病可以吃水果吗？\",\n];\n\nconst sendMessage = async (text) => {\n  const msg = text || inputMsg.value;\n  if (!msg.trim()) return;\n  inputMsg.value = \"\";\n  loading.value = true;\n\n  messages.value.push({ role: \"user\", content: msg });\n  scrollToBottom();\n\n  try {\n    const res = await chatApi.send({ userId: userStore.userId, query: msg, sessionId: \"\" });\n    if (res.code === 200) {\n      messages.value.push({ role: \"ai\", content: res.data.reply });\n    }\n  } catch (e) {\n    messages.value.push({ role: \"ai\", content: \"抱歉，我暂时无法回答，请稍后再试。\" });\n  }\n  loading.value = false;\n  scrollToBottom();\n};\n\nconst scrollToBottom = async () => {\n  await nextTick();\n  if (msgRef.value) {\n    msgRef.value.scrollTop = msgRef.value.scrollHeight;\n  }\n};\n</script>\n\n<style scoped>\n.smart-assistant { display: flex; flex-direction: column; height: calc(100vh - 60px - 56px); max-width: 500px; margin: 0 auto; }\n.chat-header { display: flex; align-items: center; gap: 8px; padding: 16px; background: #fff; border-bottom: 1px solid #f0f0f0; }\n.chat-header h3 { font-size: 18px; flex: 1; }\n.ai-tag { background: #409eff; color: #fff; padding: 2px 8px; border-radius: 4px; font-size: 11px; }\n.chat-messages { flex: 1; overflow-y: auto; padding: 16px; }\n.msg-item { display: flex; gap: 10px; margin-bottom: 16px; }\n.msg-item.user { flex-direction: row-reverse; }\n.msg-content { max-width: 75%; padding: 12px; border-radius: 12px; font-size: 14px; line-height: 1.5; }\n.msg-item.ai .msg-content { background: #f0f2f5; color: #303133; border-bottom-left-radius: 4px; }\n.msg-item.user .msg-content { background: #409eff; color: #fff; border-bottom-right-radius: 4px; }\n.thinking { color: #909399 !important; }\n.welcome-tip { text-align: center; padding: 40px 0; }\n.welcome-tip h4 { margin: 12px 0 6px; font-size: 16px; color: #303133; }\n.welcome-tip p { font-size: 14px; color: #909399; }\n.quick-questions { display: flex; flex-wrap: wrap; gap: 8px; padding: 0 16px 12px; }\n.q-tag { cursor: pointer; }\n.chat-input { padding: 12px 16px; background: #fff; border-top: 1px solid #f0f0f0; }\n</style>\n"],"mappings":";AA8CA,SAASA,GAAG,EAAEC,QAAQ,QAAQ,KAAK;AACnC,SAASC,OAAO,QAAQ,oBAAoB;AAC5C,SAASC,YAAY,QAAQ,sBAAsB;;;;;;;IAEnD,MAAMC,SAAS,GAAGD,YAAY,CAAC,CAAC;IAChC,MAAME,QAAQ,GAAGL,GAAG,CAAC,EAAE,CAAC;IACxB,MAAMM,QAAQ,GAAGN,GAAG,CAAC,EAAE,CAAC;IACxB,MAAMO,OAAO,GAAGP,GAAG,CAAC,KAAK,CAAC;IAC1B,MAAMQ,MAAM,GAAGR,GAAG,CAAC,IAAI,CAAC;IAExB,MAAMS,cAAc,GAAG,CACrB,cAAc,EACd,gBAAgB,EAChB,aAAa,EACb,YAAY,CACb;IAED,MAAMC,WAAW,GAAG,MAAOC,IAAI,IAAK;MAClC,MAAMC,GAAG,GAAGD,IAAI,IAAIL,QAAQ,CAACO,KAAK;MAClC,IAAI,CAACD,GAAG,CAACE,IAAI,CAAC,CAAC,EAAE;MACjBR,QAAQ,CAACO,KAAK,GAAG,EAAE;MACnBN,OAAO,CAACM,KAAK,GAAG,IAAI;MAEpBR,QAAQ,CAACQ,KAAK,CAACE,IAAI,CAAC;QAAEC,IAAI,EAAE,MAAM;QAAEC,OAAO,EAAEL;MAAI,CAAC,CAAC;MACnDM,cAAc,CAAC,CAAC;MAEhB,IAAI;QACF,MAAMC,GAAG,GAAG,MAAMjB,OAAO,CAACkB,IAAI,CAAC;UAAEC,MAAM,EAAEjB,SAAS,CAACiB,MAAM;UAAEC,KAAK,EAAEV,GAAG;UAAEW,SAAS,EAAE;QAAG,CAAC,CAAC;QACvF,IAAIJ,GAAG,CAACK,IAAI,KAAK,GAAG,EAAE;UACpBnB,QAAQ,CAACQ,KAAK,CAACE,IAAI,CAAC;YAAEC,IAAI,EAAE,IAAI;YAAEC,OAAO,EAAEE,GAAG,CAACM,IAAI,CAACC;UAAM,CAAC,CAAC;QAC9D;MACF,CAAC,CAAC,OAAOC,CAAC,EAAE;QACVtB,QAAQ,CAACQ,KAAK,CAACE,IAAI,CAAC;UAAEC,IAAI,EAAE,IAAI;UAAEC,OAAO,EAAE;QAAoB,CAAC,CAAC;MACnE;