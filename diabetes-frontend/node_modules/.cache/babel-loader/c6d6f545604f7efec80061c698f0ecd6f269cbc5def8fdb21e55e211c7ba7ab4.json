{"ast":null,"code":"import { onMounted } from \"vue\";\n\n// 背景粒子：多色 + 三层视差（大慢近景 / 中景 / 小快远景），营造氛围与深度\nconst BURST_SELECTOR = \"button, .el-button, .nav-item, .quick-item, .action-item, .checkin-item, .article-card, .doctor-card, .cat-tag, .predict-btn, .login-btn, .register-btn, .send-btn, .submit-btn, .history-item, .tab-pane\";\nexport default {\n  __name: 'App',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const PARTICLE_COLORS = [\"34, 211, 238\", \"14, 165, 233\", \"125, 211, 252\", \"255, 255, 255\"];\n    const particleStyle = n => {\n      const color = PARTICLE_COLORS[n % PARTICLE_COLORS.length];\n      const layer = n % 3;\n      const size = layer === 0 ? 6 + n % 3 : layer === 1 ? 3.5 + n % 2 : 1.5 + n % 2;\n      const dur = layer === 0 ? 24 + n % 9 : layer === 1 ? 16 + n % 7 : 10 + n % 5;\n      const left = (n * 23 + 7) % 100;\n      const delay = n * 1.1 % 14;\n      const drift = (n % 2 === 0 ? 1 : -1) * (18 + n % 6 * 14);\n      return {\n        left: left + \"%\",\n        width: size + \"px\",\n        height: size + \"px\",\n        animationDelay: delay + \"s\",\n        animationDuration: dur + \"s\",\n        \"--drift\": drift + \"px\",\n        background: `radial-gradient(circle, rgba(${color}, 0.95), rgba(${color}, 0.12))`,\n        boxShadow: `0 0 ${4 + size}px rgba(${color}, 0.75)`\n      };\n    };\n\n    // 点击交互元素时爆发粒子（按钮 / 卡片 / 导航等）\n    const BURST_COLORS = [\"#22d3ee\", \"#0ea5e9\", \"#06b6d4\", \"#f59e0b\", \"#ffffff\"];\n    const spawnParticles = (x, y) => {\n      const wrap = document.createElement(\"div\");\n      wrap.className = \"click-burst\";\n      wrap.style.left = x + \"px\";\n      wrap.style.top = y + \"px\";\n      const count = 12;\n      for (let i = 0; i < count; i++) {\n        const p = document.createElement(\"span\");\n        const angle = Math.PI * 2 * i / count + Math.random() * 0.5;\n        const dist = 30 + Math.random() * 50;\n        const color = BURST_COLORS[i % BURST_COLORS.length];\n        p.style.setProperty(\"--dx\", Math.cos(angle) * dist + \"px\");\n        p.style.setProperty(\"--dy\", Math.sin(angle) * dist + \"px\");\n        const sz = 4 + Math.random() * 5;\n        p.style.width = sz + \"px\";\n        p.style.height = sz + \"px\";\n        p.style.background = color;\n        p.style.boxShadow = \"0 0 8px \" + color;\n        wrap.appendChild(p);\n      }\n      document.body.appendChild(wrap);\n      setTimeout(() => wrap.remove(), 700);\n    };\n    onMounted(() => {\n      document.addEventListener(\"click\", e => {\n        const el = e.target.closest && e.target.closest(BURST_SELECTOR);\n        if (el) spawnParticles(e.clientX, e.clientY);\n      });\n    });\n    const __returned__ = {\n      PARTICLE_COLORS,\n      particleStyle,\n      BURST_COLORS,\n      BURST_SELECTOR,\n      spawnParticles,\n      onMounted\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["onMounted","BURST_SELECTOR","PARTICLE_COLORS","particleStyle","n","color","length","layer","size","dur","left","delay","drift","width","height","animationDelay","animationDuration","background","boxShadow","BURST_COLORS","spawnParticles","x","y","wrap","document","createElement","className","style","top","count","i","p","angle","Math","PI","random","dist","setProperty","cos","sin","sz","appendChild","body","setTimeout","remove","addEventListener","e","el","target","closest","clientX","clientY"],"sources":["D:/软件系统实训/diabetes-frontend/src/App.vue"],"sourcesContent":["<template>\n  <div id=\"app-container\">\n    <!-- 全局动态背景层：极光光斑 + 科技网格 + 漂浮粒子 -->\n    <div class=\"bg-fx\" aria-hidden=\"true\">\n      <div class=\"aurora aurora-1\"></div>\n      <div class=\"aurora aurora-2\"></div>\n      <div class=\"aurora aurora-3\"></div>\n      <div class=\"grid-lines\"></div>\n      <div class=\"particles\">\n        <span v-for=\"n in 42\" :key=\"n\" class=\"particle\" :style=\"particleStyle(n)\"></span>\n      </div>\n    </div>\n    <router-view />\n  </div>\n</template>\n\n<script setup>\nimport { onMounted } from \"vue\";\n\n// 背景粒子：多色 + 三层视差（大慢近景 / 中景 / 小快远景），营造氛围与深度\nconst PARTICLE_COLORS = [\"34, 211, 238\", \"14, 165, 233\", \"125, 211, 252\", \"255, 255, 255\"];\nconst particleStyle = (n) => {\n  const color = PARTICLE_COLORS[n % PARTICLE_COLORS.length];\n  const layer = n % 3;\n  const size = layer === 0 ? 6 + (n % 3) : layer === 1 ? 3.5 + (n % 2) : 1.5 + (n % 2);\n  const dur = layer === 0 ? 24 + (n % 9) : layer === 1 ? 16 + (n % 7) : 10 + (n % 5);\n  const left = (n * 23 + 7) % 100;\n  const delay = (n * 1.1) % 14;\n  const drift = (n % 2 === 0 ? 1 : -1) * (18 + (n % 6) * 14);\n  return {\n    left: left + \"%\",\n    width: size + \"px\",\n    height: size + \"px\",\n    animationDelay: delay + \"s\",\n    animationDuration: dur + \"s\",\n    \"--drift\": drift + \"px\",\n    background: `radial-gradient(circle, rgba(${color}, 0.95), rgba(${color}, 0.12))`,\n    boxShadow: `0 0 ${4 + size}px rgba(${color}, 0.75)`,\n  };\n};\n\n// 点击交互元素时爆发粒子（按钮 / 卡片 / 导航等）\nconst BURST_COLORS = [\"#22d3ee\", \"#0ea5e9\", \"#06b6d4\", \"#f59e0b\", \"#ffffff\"];\nconst BURST_SELECTOR =\n  \"button, .el-button, .nav-item, .quick-item, .action-item, .checkin-item, .article-card, .doctor-card, .cat-tag, .predict-btn, .login-btn, .register-btn, .send-btn, .submit-btn, .history-item, .tab-pane\";\n\nconst spawnParticles = (x, y) => {\n  const wrap = document.createElement(\"div\");\n  wrap.className = \"click-burst\";\n  wrap.style.left = x + \"px\";\n  wrap.style.top = y + \"px\";\n  const count = 12;\n  for (let i = 0; i < count; i++) {\n    const p = document.createElement(\"span\");\n    const angle = (Math.PI * 2 * i) / count + Math.random() * 0.5;\n    const dist = 30 + Math.random() * 50;\n    const color = BURST_COLORS[i % BURST_COLORS.length];\n    p.style.setProperty(\"--dx\", Math.cos(angle) * dist + \"px\");\n    p.style.setProperty(\"--dy\", Math.sin(angle) * dist + \"px\");\n    const sz = 4 + Math.random() * 5;\n    p.style.width = sz + \"px\";\n    p.style.height = sz + \"px\";\n    p.style.background = color;\n    p.style.boxShadow = \"0 0 8px \" + color;\n    wrap.appendChild(p);\n  }\n  document.body.appendChild(wrap);\n  setTimeout(() => wrap.remove(), 700);\n};\n\nonMounted(() => {\n  document.addEventListener(\"click\", (e) => {\n    const el = e.target.closest && e.target.closest(BURST_SELECTOR);\n    if (el) spawnParticles(e.clientX, e.clientY);\n  });\n});\n</script>\n\n<style>\nhtml, body, #app, #app-container {\n  height: 100%;\n  width: 100%;\n  margin: 0;\n  padding: 0;\n}\n#app-container { position: relative; }\n\n/* ===== 动态背景层 ===== */\n.bg-fx {\n  position: fixed;\n  inset: 0;\n  z-index: 0;\n  overflow: hidden;\n  pointer-events: none;\n}\n\n/* 极光光斑 */\n.aurora {\n  position: absolute;\n  border-radius: 50%;\n  filter: blur(70px);\n  opacity: 0.55;\n  animation: auroraMove 24s ease-in-out infinite;\n}\n.aurora-1 {\n  width: 500px; height: 500px;\n  top: -140px; left: -120px;\n  background: radial-gradient(circle, rgba(34, 211, 238, 0.55), transparent 70%);\n}\n.aurora-2 {\n  width: 440px; height: 440px;\n  bottom: -120px; right: -90px;\n  background: radial-gradient(circle, rgba(14, 165, 233, 0.5), transparent 70%);\n  animation-delay: -8s;\n}\n.aurora-3 {\n  width: 380px; height: 380px;\n  top: 38%; left: 45%;\n  background: radial-gradient(circle, rgba(6, 182, 212, 0.4), transparent 70%);\n  animation-delay: -16s;\n}\n\n/* 科技网格线 */\n.grid-lines {\n  position: absolute;\n  inset: 0;\n  background-image:\n    linear-gradient(rgba(34, 211, 238, 0.06) 1px, transparent 1px),\n    linear-gradient(90deg, rgba(34, 211, 238, 0.06) 1px, transparent 1px);\n  background-size: 42px 42px;\n  -webkit-mask-image: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.7), transparent 75%);\n  mask-image: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.7), transparent 75%);\n}\n\n/* 漂浮粒子 */\n.particles { position: absolute; inset: 0; }\n.particle {\n  position: absolute;\n  bottom: -12px;\n  border-radius: 50%;\n  background: radial-gradient(circle, rgba(34, 211, 238, 0.95), rgba(34, 211, 238, 0.15));\n  box-shadow: 0 0 10px rgba(34, 211, 238, 0.7);\n  animation: particleDrift linear infinite;\n}\n\n@keyframes auroraMove {\n  0%   { transform: translate(0, 0) scale(1); }\n  33%  { transform: translate(44px, -32px) scale(1.12); }\n  66%  { transform: translate(-32px, 42px) scale(0.94); }\n  100% { transform: translate(0, 0) scale(1); }\n}\n@keyframes particleDrift {\n  0%   { transform: translateY(0) translateX(0); opacity: 0; }\n  8%   { opacity: 0.9; }\n  92%  { opacity: 0.9; }\n  100% { transform: translateY(-106vh) translateX(var(--drift, 42px)); opacity: 0; }\n}\n\n/* ===== 点击粒子爆发 ===== */\n.click-burst {\n  position: fixed;\n  z-index: 9999;\n  pointer-events: none;\n}\n.click-burst span {\n  position: absolute;\n  border-radius: 50%;\n  transform: translate(-50%, -50%);\n  animation: clickBurst 0.65s cubic-bezier(0.16, 1, 0.3, 1) forwards;\n}\n@keyframes clickBurst {\n  0%   { transform: translate(-50%, -50%) translate(0, 0) scale(1); opacity: 1; }\n  100% { transform: translate(-50%, -50%) translate(var(--dx), var(--dy)) scale(0.2); opacity: 0; }\n}\n</style>\n"],"mappings":"AAiBA,SAASA,SAAS,QAAQ,KAAK;;AAE/B;AAwBA,MAAMC,cAAc,GAClB,2MAA2M;;;;;;;IAxB7M,MAAMC,eAAe,GAAG,CAAC,cAAc,EAAE,cAAc,EAAE,eAAe,EAAE,eAAe,CAAC;IAC1F,MAAMC,aAAa,GAAIC,CAAC,IAAK;MAC3B,MAAMC,KAAK,GAAGH,eAAe,CAACE,CAAC,GAAGF,eAAe,CAACI,MAAM,CAAC;MACzD,MAAMC,KAAK,GAAGH,CAAC,GAAG,CAAC;MACnB,MAAMI,IAAI,GAAGD,KAAK,KAAK,CAAC,GAAG,CAAC,GAAIH,CAAC,GAAG,CAAE,GAAGG,KAAK,KAAK,CAAC,GAAG,GAAG,GAAIH,CAAC,GAAG,CAAE,GAAG,GAAG,GAAIA,CAAC,GAAG,CAAE;MACpF,MAAMK,GAAG,GAAGF,KAAK,KAAK,CAAC,GAAG,EAAE,GAAIH,CAAC,GAAG,CAAE,GAAGG,KAAK,KAAK,CAAC,GAAG,EAAE,GAAIH,CAAC,GAAG,CAAE,GAAG,EAAE,GAAIA,CAAC,GAAG,CAAE;MAClF,MAAMM,IAAI,GAAG,CAACN,CAAC,GAAG,EAAE,GAAG,CAAC,I