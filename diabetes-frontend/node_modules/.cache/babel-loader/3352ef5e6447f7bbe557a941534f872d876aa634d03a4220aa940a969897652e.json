{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport { ref, computed, onMounted } from \"vue\";\nimport { useRouter } from \"vue-router\";\nimport { articleApi } from \"../../api/index.js\";\nexport default {\n  __name: 'HealthArticle',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const router = useRouter();\n    const articles = ref([]);\n    const activeCategory = ref(\"\");\n    const categories = [\"饮食\", \"运动\", \"用药\", \"科普\", \"并发症\"];\n    const filteredList = computed(() => {\n      if (!activeCategory.value) return articles.value;\n      return articles.value.filter(a => a.category === activeCategory.value);\n    });\n    const formatTime = t => t ? t.slice(0, 10) : \"\";\n    const goDetail = id => router.push(`/patient/article/detail/${id}`);\n    onMounted(async () => {\n      const res = await articleApi.listPublished();\n      if (res.code === 200) articles.value = res.data || [];\n    });\n    const __returned__ = {\n      router,\n      articles,\n      activeCategory,\n      categories,\n      filteredList,\n      formatTime,\n      goDetail,\n      ref,\n      computed,\n      onMounted,\n      get useRouter() {\n        return useRouter;\n      },\n      get articleApi() {\n        return articleApi;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","onMounted","useRouter","articleApi","router","articles","activeCategory","categories","filteredList","value","filter","a","category","formatTime","t","slice","goDetail","id","push","res","listPublished","code","data"],"sources":["E:/WebDevelopment/STS5workspace/实训文件夹/diabetes-frontend/src/views/patient/HealthArticle.vue"],"sourcesContent":["<template>\n  <div class=\"health-article\">\n    <div class=\"page-header\"><h3>健康资讯</h3></div>\n\n    <!-- 分类标签 -->\n    <div class=\"category-tabs\">\n      <el-tag :type=\"activeCategory === '' ? 'primary' : 'info'\" @click=\"activeCategory = ''\" class=\"cat-tag\">全部</el-tag>\n      <el-tag v-for=\"cat in categories\" :key=\"cat\" :type=\"activeCategory === cat ? 'primary' : 'info'\" @click=\"activeCategory = cat\" class=\"cat-tag\">{{ cat }}</el-tag>\n    </div>\n\n    <!-- 文章列表 -->\n    <div class=\"article-list\">\n      <div v-for=\"item in filteredList\" :key=\"item.id\" class=\"article-card\" @click=\"goDetail(item.id)\">\n        <div class=\"article-info\">\n          <div class=\"article-title\">{{ item.title }}</div>\n          <div class=\"article-summary\">{{ item.summary }}</div>\n          <div class=\"article-meta\">\n            <el-tag size=\"small\">{{ item.category }}</el-tag>\n            <span class=\"views\">{{ item.views || 0 }}次浏览</span>\n            <span class=\"date\">{{ formatTime(item.createdTime) }}</span>\n          </div>\n        </div>\n      </div>\n      <div v-if=\"filteredList.length === 0\" class=\"empty-tip\">暂无资讯</div>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, computed, onMounted } from \"vue\";\nimport { useRouter } from \"vue-router\";\nimport { articleApi } from \"../../api/index.js\";\n\nconst router = useRouter();\nconst articles = ref([]);\nconst activeCategory = ref(\"\");\n\nconst categories = [\"饮食\", \"运动\", \"用药\", \"科普\", \"并发症\"];\n\nconst filteredList = computed(() => {\n  if (!activeCategory.value) return articles.value;\n  return articles.value.filter(a => a.category === activeCategory.value);\n});\n\nconst formatTime = (t) => t ? t.slice(0, 10) : \"\";\n\nconst goDetail = (id) => router.push(`/patient/article/detail/${id}`);\n\nonMounted(async () => {\n  const res = await articleApi.listPublished();\n  if (res.code === 200) articles.value = res.data || [];\n});\n</script>\n\n<style scoped>\n.health-article { padding: 16px; max-width: 500px; margin: 0 auto; }\n.page-header h3 { font-size: 20px; margin-bottom: 16px; }\n.category-tabs { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 16px; }\n.cat-tag { cursor: pointer; }\n.article-card { background: #fff; border-radius: 12px; padding: 16px; margin-bottom: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); cursor: pointer; }\n.article-title { font-size: 15px; font-weight: bold; color: #303133; margin-bottom: 6px; }\n.article-summary { font-size: 13px; color: #909399; margin-bottom: 8px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }\n.article-meta { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }\n.views, .date { font-size: 12px; color: #c0c4cc; }\n.empty-tip { text-align: center; padding: 40px; color: #909399; }\n</style>\n"],"mappings":";;;AA6BA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,SAAS,QAAQ,KAAK;AAC9C,SAASC,SAAS,QAAQ,YAAY;AACtC,SAASC,UAAU,QAAQ,oBAAoB;;;;;;;IAE/C,MAAMC,MAAM,GAAGF,SAAS,CAAC,CAAC;IAC1B,MAAMG,QAAQ,GAAGN,GAAG,CAAC,EAAE,CAAC;IACxB,MAAMO,cAAc,GAAGP,GAAG,CAAC,EAAE,CAAC;IAE9B,MAAMQ,UAAU,GAAG,CAAC,IAAI,EAAE,IAAI,EAAE,IAAI,EAAE,IAAI,EAAE,KAAK,CAAC;IAElD,MAAMC,YAAY,GAAGR,QAAQ,CAAC,MAAM;MAClC,IAAI,CAACM,cAAc,CAACG,KAAK,EAAE,OAAOJ,QAAQ,CAACI,KAAK;MAChD,OAAOJ,QAAQ,CAACI,KAAK,CAACC,MAAM,CAACC,CAAC,IAAIA,CAAC,CAACC,QAAQ,KAAKN,cAAc,CAACG,KAAK,CAAC;IACxE,CAAC,CAAC;IAEF,MAAMI,UAAU,GAAIC,CAAC,IAAKA,CAAC,GAAGA,CAAC,CAACC,KAAK,CAAC,CAAC,EAAE,EAAE,CAAC,GAAG,EAAE;IAEjD,MAAMC,QAAQ,GAAIC,EAAE,IAAKb,MAAM,CAACc,IAAI,CAAC,2BAA2BD,EAAE,EAAE,CAAC;IAErEhB,SAAS,CAAC,YAAY;MACpB,MAAMkB,GAAG,GAAG,MAAMhB,UAAU,CAACiB,aAAa,CAAC,CAAC;MAC5C,IAAID,GAAG,CAACE,IAAI,KAAK,GAAG,EAAEhB,QAAQ,CAACI,KAAK,GAAGU,GAAG,CAACG,IAAI,IAAI,EAAE;IACvD,CAAC,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}