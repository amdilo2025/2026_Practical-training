{"ast":null,"code":"import { ref, onMounted } from \"vue\";\nimport { useUserStore } from \"../../store/index.js\";\nimport { dashboardApi } from \"../../api/index.js\";\nexport default {\n  __name: 'Dashboard',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const userStore = useUserStore();\n    const userInfo = ref({});\n    const articles = ref([]);\n    const consultations = ref([]);\n    const todaySugar = ref(\"\");\n    onMounted(async () => {\n      userInfo.value = userStore.userInfo || {};\n      try {\n        const res = await dashboardApi.patient(userStore.userId);\n        if (res.code === 200) {\n          articles.value = res.data.recommendedArticles || [];\n          consultations.value = res.data.recentConsultations || [];\n        }\n      } catch (_) {/* 忽略 */}\n    });\n    const __returned__ = {\n      userStore,\n      userInfo,\n      articles,\n      consultations,\n      todaySugar,\n      ref,\n      onMounted,\n      get useUserStore() {\n        return useUserStore;\n      },\n      get dashboardApi() {\n        return dashboardApi;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","onMounted","useUserStore","dashboardApi","userStore","userInfo","articles","consultations","todaySugar","value","res","patient","userId","code","data","recommendedArticles","recentConsultations","_"],"sources":["E:/WebDevelopment/STS5workspace/实训文件夹/diabetes-frontend/src/views/patient/Dashboard.vue"],"sourcesContent":["<template>\n  <div class=\"patient-dashboard\">\n    <!-- 用户问候 -->\n    <div class=\"greeting-card\">\n      <div class=\"greeting-text\">\n        <h3>你好，{{ userInfo?.name || '用户' }}</h3>\n        <p>今日血糖: {{ todaySugar || '未记录' }}</p>\n      </div>\n      <div class=\"greeting-icon\">\n        <el-avatar :size=\"56\" icon=\"User\" />\n      </div>\n    </div>\n\n    <!-- 快捷操作 -->\n    <div class=\"quick-actions\">\n      <div class=\"action-item\" @click=\"$router.push('/patient/checkin')\">\n        <el-icon :size=\"28\" color=\"#67c23a\"><Check /></el-icon>\n        <span>今日打卡</span>\n      </div>\n      <div class=\"action-item\" @click=\"$router.push('/patient/risk')\">\n        <el-icon :size=\"28\" color=\"#e6a23c\"><Warning /></el-icon>\n        <span>风险评估</span>\n      </div>\n      <div class=\"action-item\" @click=\"$router.push('/patient/doctor')\">\n        <el-icon :size=\"28\" color=\"#409eff\"><ChatDotSquare /></el-icon>\n        <span>医师咨询</span>\n      </div>\n      <div class=\"action-item\" @click=\"$router.push('/patient/chat')\">\n        <el-icon :size=\"28\" color=\"#9b59b6\"><MagicStick /></el-icon>\n        <span>智能助手</span>\n      </div>\n    </div>\n\n    <!-- 最新资讯 -->\n    <div class=\"section\">\n      <div class=\"section-header\">\n        <span class=\"section-title\">健康资讯</span>\n        <el-button text type=\"primary\" @click=\"$router.push('/patient/article')\">更多</el-button>\n      </div>\n      <div v-for=\"item in articles.slice(0, 3)\" :key=\"item.id\" class=\"article-card\" @click=\"$router.push(`/patient/article/detail/${item.id}`)\">\n        <div class=\"article-info\">\n          <div class=\"article-title\">{{ item.title }}</div>\n          <div class=\"article-meta\">\n            <el-tag size=\"small\">{{ item.category }}</el-tag>\n            <span class=\"article-views\">{{ item.views }}次浏览</span>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- 最近咨询 -->\n    <div class=\"section\">\n      <div class=\"section-header\">\n        <span class=\"section-title\">最近咨询</span>\n        <el-button text type=\"primary\" @click=\"$router.push('/patient/doctor')\">更多</el-button>\n      </div>\n      <div v-for=\"item in consultations.slice(0, 3)\" :key=\"item.id\" class=\"consult-item\">\n        <div class=\"consult-doctor\">{{ item.doctor_name || '医师' }}</div>\n        <div class=\"consult-content\">{{ item.content }}</div>\n        <el-tag size=\"small\" :type=\"item.status === '已回复' ? 'success' : 'warning'\">{{ item.status }}</el-tag>\n      </div>\n      <div v-if=\"consultations.length === 0\" class=\"empty-tip\">暂无咨询记录</div>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, onMounted } from \"vue\";\nimport { useUserStore } from \"../../store/index.js\";\nimport { dashboardApi } from \"../../api/index.js\";\n\nconst userStore = useUserStore();\nconst userInfo = ref({});\nconst articles = ref([]);\nconst consultations = ref([]);\nconst todaySugar = ref(\"\");\n\nonMounted(async () => {\n  userInfo.value = userStore.userInfo || {};\n  try {\n    const res = await dashboardApi.patient(userStore.userId);\n    if (res.code === 200) {\n      articles.value = res.data.recommendedArticles || [];\n      consultations.value = res.data.recentConsultations || [];\n    }\n  } catch (_) { /* 忽略 */ }\n});\n</script>\n\n<style scoped>\n.patient-dashboard { padding: 16px; max-width: 500px; margin: 0 auto; }\n.greeting-card {\n  background: linear-gradient(135deg, #409eff, #337ecc);\n  border-radius: 12px;\n  padding: 20px;\n  color: #fff;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 16px;\n}\n.greeting-text h3 { font-size: 20px; margin-bottom: 6px; }\n.greeting-text p { font-size: 14px; opacity: 0.9; }\n.quick-actions {\n  display: grid;\n  grid-template-columns: repeat(4, 1fr);\n  gap: 12px;\n  margin-bottom: 16px;\n}\n.action-item {\n  background: #fff;\n  border-radius: 12px;\n  padding: 16px 8px;\n  text-align: center;\n  box-shadow: 0 2px 8px rgba(0,0,0,0.06);\n  cursor: pointer;\n}\n.action-item span { display: block; font-size: 12px; color: #606266; margin-top: 6px; }\n.section { background: #fff; border-radius: 12px; padding: 16px; margin-bottom: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }\n.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }\n.section-title { font-size: 16px; font-weight: bold; color: #303133; }\n.article-card { padding: 12px 0; border-bottom: 1px solid #f0f0f0; cursor: pointer; }\n.article-card:last-child { border-bottom: none; }\n.article-title { font-size: 14px; color: #303133; margin-bottom: 6px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }\n.article-meta { display: flex; align-items: center; gap: 8px; }\n.article-views { font-size: 12px; color: #909399; }\n.consult-item { padding: 10px 0; border-bottom: 1px solid #f0f0f0; font-size: 13px; }\n.consult-item:last-child { border-bottom: none; }\n.consult-doctor { font-weight: bold; color: #409eff; margin-bottom: 4px; }\n.consult-content { color: #606266; margin-bottom: 4px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }\n.empty-tip { text-align: center; color: #909399; padding: 20px 0; font-size: 14px; }\n</style>\n"],"mappings":"AAmEA,SAASA,GAAG,EAAEC,SAAS,QAAQ,KAAK;AACpC,SAASC,YAAY,QAAQ,sBAAsB;AACnD,SAASC,YAAY,QAAQ,oBAAoB;;;;;;;IAEjD,MAAMC,SAAS,GAAGF,YAAY,CAAC,CAAC;IAChC,MAAMG,QAAQ,GAAGL,GAAG,CAAC,CAAC,CAAC,CAAC;IACxB,MAAMM,QAAQ,GAAGN,GAAG,CAAC,EAAE,CAAC;IACxB,MAAMO,aAAa,GAAGP,GAAG,CAAC,EAAE,CAAC;IAC7B,MAAMQ,UAAU,GAAGR,GAAG,CAAC,EAAE,CAAC;IAE1BC,SAAS,CAAC,YAAY;MACpBI,QAAQ,CAACI,KAAK,GAAGL,SAAS,CAACC,QAAQ,IAAI,CAAC,CAAC;MACzC,IAAI;QACF,MAAMK,GAAG,GAAG,MAAMP,YAAY,CAACQ,OAAO,CAACP,SAAS,CAACQ,MAAM,CAAC;QACxD,IAAIF,GAAG,CAACG,IAAI,KAAK,GAAG,EAAE;UACpBP,QAAQ,CAACG,KAAK,GAAGC,GAAG,CAACI,IAAI,CAACC,mBAAmB,IAAI,EAAE;UACnDR,aAAa,CAACE,KAAK,GAAGC,GAAG,CAACI,IAAI,CAACE,mBAAmB,IAAI,EAAE;QAC1D;MACF,CAAC,CAAC,OAAOC,CAAC,EAAE,CAAE;IAChB,CAAC,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}