{"ast":null,"code":"import { ref } from \"vue\";\nimport { Search } from \"@element-plus/icons-vue\";\nimport { adminApi } from \"../../api/index.js\";\nexport default {\n  __name: 'DataQuery',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const queryText = ref(\"\");\n    const loading = ref(false);\n    const result = ref(null);\n    const errorMsg = ref(\"\");\n    const hints = [\"查一下最近一周新增的用户\", \"待回复的咨询有哪些\", \"统计各科室的医师数量\"];\n    const doQuery = async () => {\n      if (!queryText.value.trim() || loading.value) return;\n      loading.value = true;\n      result.value = null;\n      errorMsg.value = \"\";\n      try {\n        const res = await adminApi.dataQuery({\n          query: queryText.value\n        });\n        if (res.code === 200) {\n          // 后端返回的 data 可能是 {body: {columns, rows, total}}，需要解包\n          const raw = res.data;\n          if (raw && raw.body) {\n            result.value = raw.body;\n          } else {\n            result.value = raw;\n          }\n        } else {\n          errorMsg.value = res.message || \"查询失败\";\n        }\n      } catch (e) {\n        errorMsg.value = \"查询请求失败，请检查网络或后端服务\";\n      }\n      loading.value = false;\n    };\n    const __returned__ = {\n      queryText,\n      loading,\n      result,\n      errorMsg,\n      hints,\n      doQuery,\n      ref,\n      get Search() {\n        return Search;\n      },\n      get adminApi() {\n        return adminApi;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","Search","adminApi","queryText","loading","result","errorMsg","hints","doQuery","value","trim","res","dataQuery","query","code","raw","data","body","message","e"],"sources":["D:/软件系统实训/diabetes-frontend/src/views/admin/DataQuery.vue"],"sourcesContent":["<template>\n  <div class=\"data-query\">\n    <h3 class=\"page-title\">数据查询</h3>\n\n    <el-card shadow=\"never\" class=\"query-card\">\n      <template #header>\n        <span class=\"card-header-title\">自然语言查询</span>\n      </template>\n\n      <el-input\n        v-model=\"queryText\"\n        type=\"textarea\"\n        :rows=\"3\"\n        placeholder=\"输入要查询的内容，例如：查一下最近一周新增的用户、血糖异常的用户有哪些、统计各科室的医师数量\"\n        maxlength=\"200\"\n        show-word-limit\n        @keyup.enter.ctrl=\"doQuery\"\n      />\n      <div class=\"query-bar\">\n        <div class=\"query-hints\">\n          <span class=\"hint-label\">试试看：</span>\n          <el-tag\n            v-for=\"hint in hints\"\n            :key=\"hint\"\n            size=\"small\"\n            class=\"hint-tag\"\n            @click=\"queryText = hint; doQuery()\"\n          >{{ hint }}</el-tag>\n        </div>\n        <el-button\n          type=\"primary\"\n          :loading=\"loading\"\n          :disabled=\"!queryText.trim()\"\n          @click=\"doQuery\"\n          class=\"query-btn\"\n        >\n          <el-icon><Search /></el-icon> 查询\n        </el-button>\n      </div>\n    </el-card>\n\n    <el-card v-if=\"result\" shadow=\"never\" class=\"result-card\">\n      <template #header>\n        <span class=\"card-header-title\">\n          查询结果\n          <el-tag v-if=\"result.total !== undefined\" size=\"small\" round class=\"count-tag\">\n            共 {{ result.total }} 条\n          </el-tag>\n        </span>\n      </template>\n\n      <div v-if=\"result.columns && result.rows\">\n        <!-- 表格模式 -->\n        <div class=\"table-wrap\" v-if=\"result.rows.length > 0\">\n          <el-table :data=\"result.rows\" border stripe size=\"small\" style=\"width:100%\">\n            <el-table-column\n              v-for=\"col in result.columns\"\n              :key=\"col\"\n              :prop=\"col\"\n              :label=\"col\"\n              min-width=\"120\"\n              show-overflow-tooltip\n            />\n          </el-table>\n        </div>\n        <el-empty v-else description=\"查询无结果\" :image-size=\"80\" />\n      </div>\n\n      <!-- 纯文本模式 -->\n      <div v-else-if=\"result.text\" class=\"result-text\">{{ result.text }}</div>\n\n      <!-- 兜底：整体展示 -->\n      <pre v-else class=\"result-raw\">{{ JSON.stringify(result, null, 2) }}</pre>\n    </el-card>\n\n    <el-card v-else-if=\"errorMsg\" shadow=\"never\" class=\"error-card\">\n      <el-alert :title=\"errorMsg\" type=\"error\" show-icon :closable=\"false\" />\n    </el-card>\n  </div>\n</template>\n\n<script setup>\nimport { ref } from \"vue\";\nimport { Search } from \"@element-plus/icons-vue\";\nimport { adminApi } from \"../../api/index.js\";\n\nconst queryText = ref(\"\");\nconst loading = ref(false);\nconst result = ref(null);\nconst errorMsg = ref(\"\");\n\nconst hints = [\n  \"查一下最近一周新增的用户\",\n  \"待回复的咨询有哪些\",\n  \"统计各科室的医师数量\",\n];\n\nconst doQuery = async () => {\n  if (!queryText.value.trim() || loading.value) return;\n  loading.value = true;\n  result.value = null;\n  errorMsg.value = \"\";\n\n  try {\n    const res = await adminApi.dataQuery({ query: queryText.value });\n    if (res.code === 200) {\n      // 后端返回的 data 可能是 {body: {columns, rows, total}}，需要解包\n      const raw = res.data;\n      if (raw && raw.body) {\n        result.value = raw.body;\n      } else {\n        result.value = raw;\n      }\n    } else {\n      errorMsg.value = res.message || \"查询失败\";\n    }\n  } catch (e) {\n    errorMsg.value = \"查询请求失败，请检查网络或后端服务\";\n  }\n  loading.value = false;\n};\n</script>\n\n<style scoped>\n.data-query { width: 100%; }\n.page-title {\n  font-size: 22px;\n  margin-bottom: 18px;\n  font-family: var(--font-display);\n  color: var(--gray-900);\n  letter-spacing: 0.04em;\n}\n\n.query-card { margin-bottom: 16px; }\n.card-header-title {\n  font-weight: 700;\n  font-size: 14px;\n  color: var(--gray-700);\n}\n\n.query-bar {\n  display: flex;\n  justify-content: space-between;\n  align-items: flex-start;\n  gap: 16px;\n  margin-top: 14px;\n  flex-wrap: wrap;\n}\n.query-hints {\n  display: flex;\n  align-items: center;\n  gap: 6px;\n  flex-wrap: wrap;\n  flex: 1;\n}\n.hint-label { font-size: 12px; color: var(--gray-400); white-space: nowrap; }\n.hint-tag { cursor: pointer; transition: all 0.15s; }\n.hint-tag:hover { background: var(--primary-50); color: var(--primary-700); }\n.query-btn { flex-shrink: 0; }\n\n.result-card { margin-bottom: 16px; }\n.count-tag { margin-left: 8px; }\n\n.table-wrap {\n  overflow-x: auto;\n  border-radius: 10px;\n  border: 1px solid var(--gray-100);\n}\n\n.result-text {\n  font-size: 14px;\n  color: var(--gray-700);\n  line-height: 1.7;\n  white-space: pre-wrap;\n  word-break: break-word;\n}\n.result-raw {\n  font-size: 12px;\n  color: var(--gray-500);\n  background: var(--cream);\n  padding: 12px;\n  border-radius: 8px;\n  overflow-x: auto;\n  white-space: pre-wrap;\n}\n\n.error-card { margin-bottom: 16px; }\n</style>\n"],"mappings":"AAkFA,SAASA,GAAG,QAAQ,KAAK;AACzB,SAASC,MAAM,QAAQ,yBAAyB;AAChD,SAASC,QAAQ,QAAQ,oBAAoB;;;;;;;IAE7C,MAAMC,SAAS,GAAGH,GAAG,CAAC,EAAE,CAAC;IACzB,MAAMI,OAAO,GAAGJ,GAAG,CAAC,KAAK,CAAC;IAC1B,MAAMK,MAAM,GAAGL,GAAG,CAAC,IAAI,CAAC;IACxB,MAAMM,QAAQ,GAAGN,GAAG,CAAC,EAAE,CAAC;IAExB,MAAMO,KAAK,GAAG,CACZ,cAAc,EACd,WAAW,EACX,YAAY,CACb;IAED,MAAMC,OAAO,GAAG,MAAAA,CAAA,KAAY;MAC1B,IAAI,CAACL,SAAS,CAACM,KAAK,CAACC,IAAI,CAAC,CAAC,IAAIN,OAAO,CAACK,KAAK,EAAE;MAC9CL,OAAO,CAACK,KAAK,GAAG,IAAI;MACpBJ,MAAM,CAACI,KAAK,GAAG,IAAI;MACnBH,QAAQ,CAACG,KAAK,GAAG,EAAE;MAEnB,IAAI;QACF,MAAME,GAAG,GAAG,MAAMT,QAAQ,CAACU,SAAS,CAAC;UAAEC,KAAK,EAAEV,SAAS,CAACM;QAAM,CAAC,CAAC;QAChE,IAAIE,GAAG,CAACG,IAAI,KAAK,GAAG,EAAE;UACpB;UACA,MAAMC,GAAG,GAAGJ,GAAG,CAACK,IAAI;UACpB,IAAID,GAAG,IAAIA,GAAG,CAACE,IAAI,EAAE;YACnBZ,MAAM,CAACI,KAAK,GAAGM,GAAG,CAACE,IAAI;UACzB,CAAC,MAAM;YACLZ,MAAM,CAACI,KAAK,GAAGM,GAAG;UACpB;QACF,CAAC,MAAM;UACLT,QAAQ,CAACG,KAAK,GAAGE,GAAG,CAACO,OAAO,IAAI,MAAM;QACxC;MACF,CAAC,CAAC,OAAOC,CAAC,EAAE;QACVb,QAAQ,CAACG,KAAK,GAAG,mBAAmB;MACtC;MACAL,OAAO,CAACK,KAAK,GAAG,KAAK;IACvB,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}