{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.map.js\";\nimport { ref, onMounted, nextTick, onUnmounted } from \"vue\";\nimport * as echarts from \"echarts\";\nimport { adminApi } from \"../../api/index.js\";\nexport default {\n  __name: 'Dashboard',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const stats = ref({\n      totalUsers: 0,\n      pendingConsultations: 0,\n      totalArticles: 0\n    });\n    const chartRef = ref(null);\n    let chart = null;\n    onMounted(async () => {\n      const res = await adminApi.dashboard();\n      if (res.code === 200) {\n        stats.value = res.data;\n        await nextTick();\n        chart = echarts.init(chartRef.value);\n        const trend = res.data.userTrend || [];\n        chart.setOption({\n          tooltip: {\n            trigger: \"axis\"\n          },\n          xAxis: {\n            type: \"category\",\n            data: trend.map(t => t.date)\n          },\n          yAxis: {\n            type: \"value\"\n          },\n          series: [{\n            type: \"line\",\n            data: trend.map(t => t.count),\n            smooth: true,\n            areaStyle: {\n              opacity: 0.3\n            }\n          }],\n          grid: {\n            left: \"8%\",\n            right: \"8%\",\n            bottom: \"15%\"\n          }\n        });\n      }\n    });\n    onUnmounted(() => {\n      chart?.dispose();\n    });\n    const __returned__ = {\n      stats,\n      chartRef,\n      get chart() {\n        return chart;\n      },\n      set chart(v) {\n        chart = v;\n      },\n      ref,\n      onMounted,\n      nextTick,\n      onUnmounted,\n      get echarts() {\n        return echarts;\n      },\n      get adminApi() {\n        return adminApi;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","onMounted","nextTick","onUnmounted","echarts","adminApi","stats","totalUsers","pendingConsultations","totalArticles","chartRef","chart","res","dashboard","code","value","data","init","trend","userTrend","setOption","tooltip","trigger","xAxis","type","map","t","date","yAxis","series","count","smooth","areaStyle","opacity","grid","left","right","bottom","dispose"],"sources":["E:/WebDevelopment/STS5workspace/实训文件夹/diabetes-frontend/src/views/admin/Dashboard.vue"],"sourcesContent":["<template>\n  <div class=\"admin-dashboard\">\n    <h3 class=\"page-title\">管理首页</h3>\n\n    <!-- 统计卡片 -->\n    <div class=\"stats-grid\">\n      <div class=\"stat-card\">\n        <div class=\"stat-val\">{{ stats.totalUsers }}</div>\n        <div class=\"stat-label\">用户总数</div>\n      </div>\n      <div class=\"stat-card\">\n        <div class=\"stat-val\">{{ stats.pendingConsultations }}</div>\n        <div class=\"stat-label\">待回复咨询</div>\n      </div>\n      <div class=\"stat-card\">\n        <div class=\"stat-val\">{{ stats.totalArticles }}</div>\n        <div class=\"stat-label\">资讯总数</div>\n      </div>\n    </div>\n\n    <!-- 快速入口 -->\n    <el-card shadow=\"never\" class=\"quick-card\">\n      <template #header><span style=\"font-weight: bold\">快速入口</span></template>\n      <div class=\"quick-grid\">\n        <div class=\"quick-item\" @click=\"$router.push('/admin/users')\">\n          <el-icon :size=\"28\" color=\"#409eff\"><User /></el-icon><span>用户管理</span>\n        </div>\n        <div class=\"quick-item\" @click=\"$router.push('/admin/doctors')\">\n          <el-icon :size=\"28\" color=\"#67c23a\"><UserFilled /></el-icon><span>医师管理</span>\n        </div>\n        <div class=\"quick-item\" @click=\"$router.push('/admin/articles')\">\n          <el-icon :size=\"28\" color=\"#e6a23c\"><Reading /></el-icon><span>资讯管理</span>\n        </div>\n        <div class=\"quick-item\" @click=\"$router.push('/admin/consultations')\">\n          <el-icon :size=\"28\" color=\"#f56c6c\"><ChatDotSquare /></el-icon><span>咨询管理</span>\n        </div>\n      </div>\n    </el-card>\n\n    <!-- 用户趋势 -->\n    <el-card shadow=\"never\" class=\"chart-card\">\n      <template #header><span style=\"font-weight: bold\">近30天用户增长</span></template>\n      <div ref=\"chartRef\" style=\"height: 260px\"></div>\n    </el-card>\n  </div>\n</template>\n\n<script setup>\nimport { ref, onMounted, nextTick, onUnmounted } from \"vue\";\nimport * as echarts from \"echarts\";\nimport { adminApi } from \"../../api/index.js\";\n\nconst stats = ref({ totalUsers: 0, pendingConsultations: 0, totalArticles: 0 });\nconst chartRef = ref(null);\nlet chart = null;\n\nonMounted(async () => {\n  const res = await adminApi.dashboard();\n  if (res.code === 200) {\n    stats.value = res.data;\n    await nextTick();\n    chart = echarts.init(chartRef.value);\n    const trend = res.data.userTrend || [];\n    chart.setOption({\n      tooltip: { trigger: \"axis\" },\n      xAxis: { type: \"category\", data: trend.map(t => t.date) },\n      yAxis: { type: \"value\" },\n      series: [{ type: \"line\", data: trend.map(t => t.count), smooth: true, areaStyle: { opacity: 0.3 } }],\n      grid: { left: \"8%\", right: \"8%\", bottom: \"15%\" },\n    });\n  }\n});\n\nonUnmounted(() => { chart?.dispose(); });\n</script>\n\n<style scoped>\n.admin-dashboard { max-width: 600px; margin: 0 auto; }\n.page-title { font-size: 20px; margin-bottom: 16px; }\n.stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 16px; }\n.stat-card { background: #fff; border-radius: 12px; padding: 20px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }\n.stat-val { font-size: 28px; font-weight: bold; color: #409eff; }\n.stat-label { font-size: 13px; color: #909399; margin-top: 4px; }\n.quick-card { margin-bottom: 16px; }\n.quick-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }\n.quick-item { display: flex; flex-direction: column; align-items: center; gap: 8px; padding: 16px; border-radius: 12px; background: #f5f7fa; cursor: pointer; }\n.quick-item span { font-size: 13px; color: #606266; }\n.chart-card { margin-bottom: 16px; }\n</style>\n"],"mappings":";;AAgDA,SAASA,GAAG,EAAEC,SAAS,EAAEC,QAAQ,EAAEC,WAAW,QAAQ,KAAK;AAC3D,OAAO,KAAKC,OAAO,MAAM,SAAS;AAClC,SAASC,QAAQ,QAAQ,oBAAoB;;;;;;;IAE7C,MAAMC,KAAK,GAAGN,GAAG,CAAC;MAAEO,UAAU,EAAE,CAAC;MAAEC,oBAAoB,EAAE,CAAC;MAAEC,aAAa,EAAE;IAAE,CAAC,CAAC;IAC/E,MAAMC,QAAQ,GAAGV,GAAG,CAAC,IAAI,CAAC;IAC1B,IAAIW,KAAK,GAAG,IAAI;IAEhBV,SAAS,CAAC,YAAY;MACpB,MAAMW,GAAG,GAAG,MAAMP,QAAQ,CAACQ,SAAS,CAAC,CAAC;MACtC,IAAID,GAAG,CAACE,IAAI,KAAK,GAAG,EAAE;QACpBR,KAAK,CAACS,KAAK,GAAGH,GAAG,CAACI,IAAI;QACtB,MAAMd,QAAQ,CAAC,CAAC;QAChBS,KAAK,GAAGP,OAAO,CAACa,IAAI,CAACP,QAAQ,CAACK,KAAK,CAAC;QACpC,MAAMG,KAAK,GAAGN,GAAG,CAACI,IAAI,CAACG,SAAS,IAAI,EAAE;QACtCR,KAAK,CAACS,SAAS,CAAC;UACdC,OAAO,EAAE;YAAEC,OAAO,EAAE;UAAO,CAAC;UAC5BC,KAAK,EAAE;YAAEC,IAAI,EAAE,UAAU;YAAER,IAAI,EAAEE,KAAK,CAACO,GAAG,CAACC,CAAC,IAAIA,CAAC,CAACC,IAAI;UAAE,CAAC;UACzDC,KAAK,EAAE;YAAEJ,IAAI,EAAE;UAAQ,CAAC;UACxBK,MAAM,EAAE,CAAC;YAAEL,IAAI,EAAE,MAAM;YAAER,IAAI,EAAEE,KAAK,CAACO,GAAG,CAACC,CAAC,IAAIA,CAAC,CAACI,KAAK,CAAC;YAAEC,MAAM,EAAE,IAAI;YAAEC,SAAS,EAAE;cAAEC,OAAO,EAAE;YAAI;UAAE,CAAC,CAAC;UACpGC,IAAI,EAAE;YAAEC,IAAI,EAAE,IAAI;YAAEC,KAAK,EAAE,IAAI;YAAEC,MAAM,EAAE;UAAM;QACjD,CAAC,CAAC;MACJ;IACF,CAAC,CAAC;IAEFlC,WAAW,CAAC,MAAM;MAAEQ,KAAK,EAAE2B,OAAO,CAAC,CAAC;IAAE,CAAC,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}