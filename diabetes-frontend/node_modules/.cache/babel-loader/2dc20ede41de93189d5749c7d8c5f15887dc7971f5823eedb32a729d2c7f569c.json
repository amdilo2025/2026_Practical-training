{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { ref, computed } from \"vue\";\nimport { useRouter, useRoute } from \"vue-router\";\nimport { ElMessageBox } from \"element-plus\";\nimport { useUserStore } from \"../../store/index.js\";\nexport default {\n  __name: 'Layout',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const router = useRouter();\n    const route = useRoute();\n    const userStore = useUserStore();\n    const drawerVisible = ref(false);\n    const activeMenu = computed(() => route.path);\n    const handleCommand = async cmd => {\n      if (cmd === \"logout\") {\n        await ElMessageBox.confirm(\"确定要退出登录吗？\", \"提示\", {\n          type: \"warning\"\n        });\n        userStore.logout();\n        router.push(\"/login\");\n      }\n    };\n    const __returned__ = {\n      router,\n      route,\n      userStore,\n      drawerVisible,\n      activeMenu,\n      handleCommand,\n      ref,\n      computed,\n      get useRouter() {\n        return useRouter;\n      },\n      get useRoute() {\n        return useRoute;\n      },\n      get ElMessageBox() {\n        return ElMessageBox;\n      },\n      get useUserStore() {\n        return useUserStore;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","useRouter","useRoute","ElMessageBox","useUserStore","router","route","userStore","drawerVisible","activeMenu","path","handleCommand","cmd","confirm","type","logout","push"],"sources":["E:/WebDevelopment/STS5workspace/实训文件夹/diabetes-frontend/src/views/admin/Layout.vue"],"sourcesContent":["<template>\n  <div class=\"admin-layout\">\n    <!-- 顶部导航 -->\n    <div class=\"admin-header\">\n      <div class=\"header-left\">\n        <el-button text @click=\"drawerVisible = !drawerVisible\" style=\"color: #fff; font-size: 20px\">\n          <el-icon><Menu /></el-icon>\n        </el-button>\n        <span class=\"header-title\">管理后台</span>\n      </div>\n      <div class=\"header-right\">\n        <el-dropdown @command=\"handleCommand\">\n          <span class=\"admin-user\">\n            <el-icon><User /></el-icon>\n            {{ userStore.userInfo?.name || \"管理员\" }}\n          </span>\n          <template #dropdown>\n            <el-dropdown-menu>\n              <el-dropdown-item command=\"logout\">退出登录</el-dropdown-item>\n            </el-dropdown-menu>\n          </template>\n        </el-dropdown>\n      </div>\n    </div>\n\n    <!-- 抽屉菜单 -->\n    <el-drawer v-model=\"drawerVisible\" title=\"管理菜单\" direction=\"ltr\" size=\"260px\">\n      <el-menu :default-active=\"activeMenu\" :router=\"true\" @select=\"drawerVisible = false\">\n        <el-menu-item index=\"/admin/dashboard\">\n          <el-icon><Odometer /></el-icon>\n          <span>管理首页</span>\n        </el-menu-item>\n        <el-menu-item index=\"/admin/users\">\n          <el-icon><User /></el-icon>\n          <span>用户管理</span>\n        </el-menu-item>\n        <el-menu-item index=\"/admin/doctors\">\n          <el-icon><UserFilled /></el-icon>\n          <span>医师管理</span>\n        </el-menu-item>\n        <el-menu-item index=\"/admin/articles\">\n          <el-icon><Reading /></el-icon>\n          <span>资讯管理</span>\n        </el-menu-item>\n        <el-menu-item index=\"/admin/consultations\">\n          <el-icon><ChatDotSquare /></el-icon>\n          <span>咨询管理</span>\n        </el-menu-item>\n        <el-menu-item index=\"/admin/statistics\">\n          <el-icon><DataAnalysis /></el-icon>\n          <span>数据统计</span>\n        </el-menu-item>\n      </el-menu>\n    </el-drawer>\n\n    <!-- 内容区域 -->\n    <div class=\"admin-content\">\n      <router-view />\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, computed } from \"vue\";\nimport { useRouter, useRoute } from \"vue-router\";\nimport { ElMessageBox } from \"element-plus\";\