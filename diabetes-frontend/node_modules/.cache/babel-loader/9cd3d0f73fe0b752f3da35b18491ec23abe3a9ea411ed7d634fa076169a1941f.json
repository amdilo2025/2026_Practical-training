{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { ref, computed } from \"vue\";\nimport { useRouter, useRoute } from \"vue-router\";\nimport { ElMessageBox } from \"element-plus\";\nimport { useUserStore } from \"../../store/index.js\";\nexport default {\n  __name: 'Layout',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const router = useRouter();\n    const route = useRoute();\n    const userStore = useUserStore();\n    const drawerVisible = ref(false);\n    const activeMenu = computed(() => route.path);\n    const adminInitial = computed(() => {\n      const name = userStore.userInfo?.name || \"管理员\";\n      return name.charAt(0);\n    });\n    const handleCommand = async cmd => {\n      if (cmd === \"logout\") {\n        await ElMessageBox.confirm(\"确定要退出登录吗？\", \"提示\", {\n          type: \"warning\"\n        });\n        userStore.logout();\n        router.push(\"/login\");\n      }\n    };\n    const __returned__ = {\n      router,\n      route,\n      userStore,\n      drawerVisible,\n      activeMenu,\n      adminInitial,\n      handleCommand,\n      ref,\n      computed,\n      get useRouter() {\n        return useRouter;\n      },\n      get useRoute() {\n        return useRoute;\n      },\n      get ElMessageBox() {\n        return ElMessageBox;\n      },\n      get useUserStore() {\n        return useUserStore;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","useRouter","useRoute","ElMessageBox","useUserStore","router","route","userStore","drawerVisible","activeMenu","path","adminInitial","name","userInfo","charAt","handleCommand","cmd","confirm","type","logout","push"],"sources":["E:/WebDevelopment/STS5workspace/实训文件夹/diabetes-frontend/src/views/admin/Layout.vue"],"sourcesContent":["<template>\n  <div class=\"admin-layout\">\n    <!-- 顶部导航 -->\n    <div class=\"admin-header\">\n      <div class=\"header-left\">\n        <el-button text @click=\"drawerVisible = !drawerVisible\" class=\"menu-btn\">\n          <el-icon :size=\"22\"><Menu /></el-icon>\n        </el-button>\n        <span class=\"header-title\">管理后台</span>\n      </div>\n      <div class=\"header-right\">\n        <el-dropdown @command=\"handleCommand\">\n          <span class=\"admin-user\">\n            <div class=\"user-avatar\">{{ adminInitial }}</div>\n            <span class=\"user-name\">{{ userStore.userInfo?.name || '管理员' }}</span>\n            <el-icon><ArrowDown /></el-icon>\n          </span>\n          <template #dropdown>\n            <el-dropdown-menu>\n              <el-dropdown-item command=\"logout\">\n                <el-icon><SwitchButton /></el-icon> 退出登录\n              </el-dropdown-item>\n            </el-dropdown-menu>\n          </template>\n        </el-dropdown>\n      </div>\n    </div>\n\n    <!-- 抽屉菜单 -->\n    <el-drawer v-model=\"drawerVisible\" title=\"导航菜单\" direction=\"ltr\" size=\"260px\" :with-header=\"false\" class=\"admin-drawer\">\n      <div class=\"drawer-logo\">\n        <el-icon :size=\"24\" color=\"#2b6cb0\"><MedicalKit /></el-icon>\n        <span>血糖管理助手</span>\n      </div>\n      <el-menu :default-active=\"activeMenu\" :router=\"true\" @select=\"drawerVisible = false\">\n        <el-menu-item index=\"/admin/dashboard\">\n          <el-icon><Odometer /></el-icon>\n          <span>管理首页</span>\n        </el-menu-item>\n        <el-menu-item index=\"/admin/users\">\n          <el-icon><User /></el-icon>\n          <span>用户管理</span>\n        </el-menu-item>\n        <el-menu-item index=\"/admin/doctors\">\n          <el-icon><UserFilled /></el-icon>\n          <span>医师管理</span>\n        </el-menu-item>\n        <el-menu-item index=\"/admin/articles\">\n          <el-icon><Reading /></el-icon>\n          <span>资讯管理</span>\n        </el-menu-item>\n        <el-menu-item index=\"/admin/consultations\">\n          <el-icon><ChatDotSquare /></el-icon>\n          <span>咨询管理</span>\n        </el-menu-item>\n        <el-menu-item index=\"/admin/statistics\">\n          <el-icon><DataAnalysis /></el-icon>\n          <span>数据统计</span>\n        </el-menu-item>\n      </el-menu>\n    </el-drawer>\n\n    <!-- 内容区域 -->\n    <div class=\"admin-content\">\n      <router-view />\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, computed } from \"vue\";\nimport { useRouter, useRoute } from \"vue-router\";\nimport { ElMessageBox } from \"element-plus\";\nimport { useUserStore } from \"../../store/index.js\";\n\nconst router = useRouter();\nconst route = useRoute();\nconst userStore = useUserStore();\n\nconst drawerVisible = ref(false);\nconst activeMenu = computed(() => route.path);\n\nconst adminInitial = computed(() => {\n  const name = userStore.userInfo?.name || \"管理员\";\n  return name.charAt(0);\n});\n\nconst handleCommand = async (cmd) => {\n  if (cmd === \"logout\") {\n    await ElMessageBox.confirm(\"确定要退出登录吗？\", \"提示\", { type: \"warning\" });\n    userStore.logout();\n    router.push(\"/login\");\n  }\n};\n</script>\n\n<style scoped>\n.admin-layout {\n  min-height: 100vh;\n  background: #f7fafc;\n}\n.admin-header {\n  background: #fff;\n  height: 56px;\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  padding: 0 16px;\n  color: #1a202c;\n  border-bottom: 1px solid #edf2f7;\n  position: sticky;\n  top: 0;\n  z-index: 100;\n}\n.header-left { display: flex; align-items: center; gap: 12px; }\n.menu-btn { color: #4a5568; }\n.header-title { font-size: 17px; font-weight: 700; color: #2b6cb0; }\n.admin-user {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  cursor: pointer;\n  color: #4a5568;\n  font-size: 14px;\n}\n.user-avatar {\n  width: 30px;\n  height: 30px;\n  border-radius: 50%;\n  background: #ebf4ff;\n  color: #2b6cb0;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 13px;\n  font-weight: 600;\n}\n.user-name { font-weight: 500; }\n.admin-content { padding: 16px; max-width: 800px; margin: 0 auto; }\n\n/* Drawer 样式覆盖 */\n.admin-drawer :deep(.el-drawer__body) { padding: 0; }\n.drawer-logo {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  padding: 20px;\n  font-size: 17px;\n  font-weight: 700;\n  color: #2b6cb0;\n  border-bottom: 1px solid #edf2f7;\n}\n.admin-drawer .el-menu { border-right: none; }\n</style>\n"],"mappings":";AAsEA,SAASA,GAAG,EAAEC,QAAQ,QAAQ,KAAK;AACnC,SAASC,SAAS,EAAEC,QAAQ,QAAQ,YAAY;AAChD,SAASC,YAAY,QAAQ,cAAc;AAC3C,SAASC,YAAY,QAAQ,sBAAsB;;;;;;;IAEnD,MAAMC,MAAM,GAAGJ,SAAS,CAAC,CAAC;IAC1B,MAAMK,KAAK,GAAGJ,QAAQ,CAAC,CAAC;IACxB,MAAMK,SAAS,GAAGH,YAAY,CAAC,CAAC;IAEhC,MAAMI,aAAa,GAAGT,GAAG,CAAC,KAAK,CAAC;IAChC,MAAMU,UAAU,GAAGT,QAAQ,CAAC,MAAMM,KAAK,CAACI,IAAI,CAAC;IAE7C,MAAMC,YAAY,GAAGX,QAAQ,CAAC,MAAM;MAClC,MAAMY,IAAI,GAAGL,SAAS,CAACM,QAAQ,EAAED,IAAI,IAAI,KAAK;MAC9C,OAAOA,IAAI,CAACE,MAAM,CAAC,CAAC,CAAC;IACvB,CAAC,CAAC;IAEF,MAAMC,aAAa,GAAG,MAAOC,GAAG,IAAK;MACnC,IAAIA,GAAG,KAAK,QAAQ,EAAE;QACpB,MAAMb,YAAY,CAACc,OAAO,CAAC,WAAW,EAAE,IAAI,EAAE;UAAEC,IAAI,EAAE;QAAU,CAAC,CAAC;QAClEX,SAAS,CAACY,MAAM,CAAC,CAAC;QAClBd,MAAM,CAACe,IAAI,CAAC,QAAQ,CAAC;MACvB;IACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}