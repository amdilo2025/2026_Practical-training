{"ast":null,"code":"import { ref, onMounted } from \"vue\";\nimport { ElMessage, ElMessageBox } from \"element-plus\";\nimport { userApi } from \"../../api/index.js\";\nexport default {\n  __name: 'UserManage',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const users = ref([]);\n    const loadData = async () => {\n      const res = await userApi.list();\n      if (res.code === 200) users.value = res.data || [];\n    };\n    const toggleStatus = async row => {\n      await ElMessageBox.confirm(`确定${row.status === '正常' ? '禁用' : '启用'}用户 ${row.name}？`, \"提示\", {\n        type: \"warning\"\n      });\n      row.status = row.status === '正常' ? '禁用' : '正常';\n      await userApi.update({\n        id: row.id,\n        status: row.status\n      });\n      ElMessage.success(\"操作成功\");\n      loadData();\n    };\n    onMounted(loadData);\n    const __returned__ = {\n      users,\n      loadData,\n      toggleStatus,\n      ref,\n      onMounted,\n      get ElMessage() {\n        return ElMessage;\n      },\n      get ElMessageBox() {\n        return ElMessageBox;\n      },\n      get userApi() {\n        return userApi;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","onMounted","ElMessage","ElMessageBox","userApi","users","loadData","res","list","code","value","data","toggleStatus","row","confirm","status","name","type","update","id","success"],"sources":["E:/WebDevelopment/STS5workspace/实训文件夹/diabetes-frontend/src/views/admin/UserManage.vue"],"sourcesContent":["<template>\n  <div class=\"user-manage\">\n    <h3 class=\"page-title\">用户管理</h3>\n    <el-card shadow=\"never\">\n      <el-table :data=\"users\" stripe style=\"width: 100%\">\n        <el-table-column prop=\"id\" label=\"ID\" width=\"50\" />\n        <el-table-column prop=\"name\" label=\"姓名\" width=\"80\" />\n        <el-table-column prop=\"username\" label=\"用户名\" />\n        <el-table-column prop=\"phone\" label=\"手机号\" width=\"110\" />\n        <el-table-column prop=\"age\" label=\"年龄\" width=\"50\" />\n        <el-table-column prop=\"gender\" label=\"性别\" width=\"50\" />\n        <el-table-column prop=\"status\" label=\"状态\" width=\"70\">\n          <template #default=\"scope\">\n            <el-tag :type=\"scope.row.status === '正常' ? 'success' : 'danger'\" size=\"small\">{{ scope.row.status }}</el-tag>\n          </template>\n        </el-table-column>\n        <el-table-column label=\"操作\" width=\"80\" fixed=\"right\">\n          <template #default=\"scope\">\n            <el-button :type=\"scope.row.status === '正常' ? 'warning' : 'success'\" size=\"small\" @click=\"toggleStatus(scope.row)\">\n              {{ scope.row.status === '正常' ? '禁用' : '启用' }}\n            </el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n    </el-card>\n  </div>\n</template>\n\n<script setup>\nimport { ref, onMounted } from \"vue\";\nimport { ElMessage, ElMessageBox } from \"element-plus\";\nimport { userApi } from \"../../api/index.js\";\n\nconst users = ref([]);\n\nconst loadData = async () => {\n  const res = await userApi.list();\n  if (res.code === 200) users.value = res.data || [];\n};\n\nconst toggleStatus = async (row) => {\n  await ElMessageBox.confirm(`确定${row.status === '正常' ? '禁用' : '启用'}用户 ${row.name}？`, \"提示\", { type: \"warning\" });\n  row.status = row.status === '正常' ? '禁用' : '正常';\n  await userApi.update({ id: row.id, status: row.status });\n  ElMessage.success(\"操作成功\");\n  loadData();\n};\n\nonMounted(loadData);\n</script>\n\n<style scoped>\n.user-manage { max-width: 600px; margin: 0 auto; }\n.page-title { font-size: 20px; margin-bottom: 16px; }\n</style>\n"],"mappings":"AA6BA,SAASA,GAAG,EAAEC,SAAS,QAAQ,KAAK;AACpC,SAASC,SAAS,EAAEC,YAAY,QAAQ,cAAc;AACtD,SAASC,OAAO,QAAQ,oBAAoB;;;;;;;IAE5C,MAAMC,KAAK,GAAGL,GAAG,CAAC,EAAE,CAAC;IAErB,MAAMM,QAAQ,GAAG,MAAAA,CAAA,KAAY;MAC3B