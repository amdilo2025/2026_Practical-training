{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nimport { ref, reactive, onMounted, computed } from \"vue\";\nimport { ElMessage } from \"element-plus\";\nimport { checkinApi } from \"../../api/index.js\";\nimport { useUserStore } from \"../../store/index.js\";\nexport default {\n  __name: 'DailyCheckin',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const userStore = useUserStore();\n    const records = ref([]);\n    const stats = ref({});\n    const todayStatus = reactive({\n      diet: false,\n      exercise: false,\n      medication: false,\n      measure: false\n    });\n    const checkinTypes = [{\n      key: \"diet\",\n      label: \"饮食打卡\",\n      icon: \"Food\"\n    }, {\n      key: \"exercise\",\n      label: \"运动打卡\",\n      icon: \"Help\"\n    }, {\n      key: \"medication\",\n      label: \"服药打卡\",\n      icon: \"MedicineBox\"\n    }, {\n      key: \"measure\",\n      label: \"测血糖\",\n      icon: \"DataLine\"\n    }];\n    const typeLabel = type => ({\n      diet: \"饮食\",\n      exercise: \"运动\",\n      medication: \"服药\",\n      measure: \"测血糖\"\n    })[type] || type;\n    const doCheckin = async type => {\n      if (todayStatus[type]) return ElMessage.info(\"今日已打卡\");\n      const today = new Date().toISOString().slice(0, 10);\n      const res = await checkinApi.do({\n        userId: userStore.userId,\n        checkinDate: today,\n        checkinType: type,\n        content: \"\"\n      });\n      if (res.code === 200) {\n        ElMessage.success(`${typeLabel(type)}打卡成功`);\n        await loadData();\n      } else {\n        ElMessage.warning(res.message);\n      }\n    };\n    const loadData = async () => {\n      const rRes = await checkinApi.list(userStore.userId, 7);\n      if (rRes.code === 200) records.value = rRes.data || [];\n      const sRes = await checkinApi.stats(userStore.userId, 30);\n      if (sRes.code === 200) stats.value = sRes.data || {};\n\n      // 更新今日打卡状态\n      const today = new Date().toISOString().slice(0, 10);\n      Object.keys(todayStatus).forEach(k => todayStatus[k] = false);\n      (records.value || []).forEach(r => {\n        if (r.checkin_date === today && r.status === 1) {\n          const keyMap = {\n            diet: \"diet\",\n            exercise: \"exercise\",\n            medication: \"medication\",\n            测血糖: \"measure\"\n          };\n          const k = keyMap[r.checkin_type];\n          if (k) todayStatus[k] = true;\n        }\n      });\n    };\n    onMounted(loadData);\n    const __returned__ = {\n      userStore,\n      records,\n      stats,\n      todayStatus,\n      checkinTypes,\n      typeLabel,\n      doCheckin,\n      loadData,\n      ref,\n      reactive,\n      onMounted,\n      computed,\n      get ElMessage() {\n        return ElMessage;\n      },\n      get checkinApi() {\n        return checkinApi;\n      },\n      get useUserStore() {\n        return useUserStore;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","reactive","onMounted","computed","ElMessage","checkinApi","useUserStore","userStore","records","stats","todayStatus","diet","exercise","medication","measure","checkinTypes","key","label","icon","typeLabel","type","doCheckin","info","today","Date","toISOString","slice","res","do","userId","checkinDate","checkinType","content","code","success","loadData","warning","message","rRes","list","value","data","sRes","Object","keys","forEach","k","r","checkin_date","status","keyMap","测血糖","checkin_type"],"sources":["E:/WebDevelopment/STS5workspace/实训文件夹/diabetes-frontend/src/views/patient/DailyCheckin.vue"],"sourcesContent":["<template>\n  <div class=\"daily-checkin\">\n    <div class=\"page-header\">\n      <h3>生活打卡</h3>\n    </div>\n\n    <!-- 今日打卡 -->\n    <el-card shadow=\"never\" class=\"today-card\">\n      <template #header><span style=\"font-weight: bold\">今日打卡</span></template>\n      <div class=\"checkin-types\">\n        <div v-for=\"t in checkinTypes\" :key=\"t.key\" class=\"checkin-item\" :class=\"{ done: todayStatus[t.key] }\" @click=\"doCheckin(t.key)\">\n          <el-icon :size=\"32\" :color=\"todayStatus[t.key] ? '#67c23a' : '#c0c4cc'\" :class=\"t.icon\" />\n          <span>{{ t.label }}</span>\n          <el-tag v-if=\"todayStatus[t.key]\" size=\"small\" type=\"success\">已打卡</el-tag>\n        </div>\n      </div>\n    </el-card>\n\n    <!-- 打卡统计 -->\n    <el-card shadow=\"never\" class=\"stats-card\">\n      <template #header><span style=\"font-weight: bold\">打卡统计</span></template>\n      <div class=\"stats-grid\">\n        <div class=\"stat-item\">\n          <div class=\"stat-val\">{{ stats.completionRate || 0 }}%</div>\n          <div class=\"stat-label\">完成率</div>\n        </div>\n        <div class=\"stat-item\">\n          <div class=\"stat-val\">{{ stats.activeDays || 0 }}天</div>\n          <div class=\"stat-label\">活跃天数</div>\n        </div>\n        <div class=\"stat-item\">\n          <div class=\"stat-val\">{{ stats.completedItems || 0 }}</div>\n          <div class=\"stat-label\">完成次数</div>\n        </div>\n      </div>\n      <!-- 各类型统计 -->\n      <div v-for=\"s in (stats.stats || [])\" :key=\"s.checkin_type\" class=\"type-stat\">\n        <span>{{ typeLabel(s.checkin_type) }}</span>\n        <el-progress :percentage=\"s.total_count > 0 ? Math.round(s.completed_count / s.total_count * 100) : 0\" :stroke-width=\"8\" />\n      </div>\n    </el-card>\n\n    <!-- 打卡记录 -->\n    <el-card shadow=\"never\" class=\"record-card\">\n      <template #header><span style=\"font-weight: bold\">打卡记录</span></template>\n      <div v-for=\"item in records\" :key=\"item.id\" class=\"record-item\">\n        <div class=\"record-left\">\n          <el-tag size=\"small\">{{ typeLabel(item.checkin_type) }}</el-tag>\n          <span class=\"record-content\">{{ item.content || '-' }}</span>\n        </div>\n        <span class=\"record-date\">{{ item.checkin_date }}</span>\n      </div>\n      <div v-if=\"records.length === 0\" class=\"empty-tip\">暂无打卡记录</div>\n    </el-card>\n  </div>\n</template>\n\n<script setup>\nimport { ref, reactive, onMounted, computed } from \"vue\";\nimport { ElMessage } from \"element-plus\";\nimport { checkinApi } from \"../../api/index.js\";\nimport { useUserStore } from \"../../store/index.js\";\n\nconst userStore = useUserStore();\nconst records = ref([]);\nconst stats = ref({});\nconst todayStatus = reactive({ diet: false, exercise: false, medication: false, measure: false });\n\nconst checkinTypes = [\n  { key: \"diet\", label: \"饮食打卡\", icon: \"Food\" },\n  { key: \"exercise\", label: \"运动打卡\", icon: \"Help\" },\n  { key: \"medication\", label: \"服药打卡\", icon: \"MedicineBox\" },\n  { key: \"measure\", label: \"测血糖\", icon: \"DataLine\" },\n];\n\nconst typeLabel = (type) => ({ diet: \"饮食\", exercise: \"运动\", medication: \"服药\", measure: \"测血糖\" }[type] || type);\n\nconst doCheckin = async (type) => {\n  if (todayStatus[type]) return ElMessage.info(\"今日已打卡\");\n  const today = new Date().toISOString().slice(0, 10);\n  const res = await checkinApi.do({ userId: userStore.userId, checkinDate: today, checkinType: type, content: \"\" });\n  if (res.code === 200) {\n    ElMessage.success(`${typeLabel(type)}打卡成功`);\n    await loadData();\n  } else {\n    ElMessage.warning(res.message);\n  }\n};\n\nconst loadData = async () => {\n  const rRes = await checkinApi.list(userStore.userId, 7);\n  if (rRes.code === 200) records.value = rRes.data || [];\n\n  const sRes = await checkinApi.stats(userStore.userId, 30);\n  if (sRes.code === 200) stats.value = sRes.data || {};\n\n  // 更新今日打卡状态\n  const today = new Date().toISOString().slice(0, 10);\n  Object.keys(todayStatus).forEach(k => todayStatus[k] = false);\n  (records.value || []).forEach(r => {\n    if (r.checkin_date === today && r.status === 1) {\n      const keyMap = { diet: \"diet\", exercise: \"exercise\", medication: \"medication\", 测血糖: \"measure\" };\n      const k = keyMap[r.checkin_type];\n      if (k) todayStatus[k] = true;\n    }\n  });\n};\n\nonMounted(loadData);\n</script>\n\n<style scoped>\n.daily-checkin { padding: 16px; max-width: 500px; margin: 0 auto; }\n.page-header h3 { font-size: 20px; margin-bottom: 16px; }\n.today-card, .stats-card, .record-card { margin-bottom: 16px; }\n.checkin-types { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }\n.checkin-item { display: flex; flex-direction: column; align-items: center; gap: 6px; padding: 16px; border-radius: 12px; background: #f5f7fa; cursor: pointer; transition: all 0.2s; }\n.checkin-item.done { background: #f0f9eb; }\n.checkin-item span { font-size: 13px; color: #606266; }\n.stats-grid { display: flex; justify-content: space-around; margin-bottom: 16px; }\n.stat-item { text-align: center; }\n.stat-val { font-size: 28px; font-weight: bold; color: #409eff; }\n.stat-label { font-size: 13px; color: #909399; margin-top: 4px; }\n.type-stat { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }\n.type-stat span { font-size: 13px; width: 60px; color: #606266; }\n.type-stat :deep(.el-progress) { flex: 1; }\n.record-item { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid #f0f0f0; }\n.record-item:last-child { border-bottom: none; }\n.record-left { display: flex; align-items: center; gap: 8px; flex: 1; }\n.record-content { font-size: 13px; color: #606266; }\n.record-date { font-size: 12px; color: #c0c4cc; }\n.empty-tip { text-align: center; padding: 24px; color: #909399; }\n</style>\n"],"mappings":";;AA0DA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,SAAS,EAAEC,QAAQ,QAAQ,KAAK;AACxD,SAASC,SAAS,QAAQ,cAAc;AACxC,SAASC,UAAU,QAAQ,oBAAoB;AAC/C,SAASC,YAAY,QAAQ,sBAAsB;;;;;;;IAEnD,MAAMC,SAAS,GAAGD,YAAY,CAAC,CAAC;IAChC,MAAME,OAAO,GAAGR,GAAG,CAAC,EAAE,CAAC;IACvB,MAAMS,KAAK,GAAG