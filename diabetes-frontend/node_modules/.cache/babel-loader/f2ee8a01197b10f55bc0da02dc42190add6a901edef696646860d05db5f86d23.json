{"ast":null,"code":"import { ref, onMounted } from \"vue\";\nimport { ElMessage } from \"element-plus\";\nimport { consultationApi } from \"../../api/index.js\";\nexport default {\n  __name: 'ConsultationManage',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const consultations = ref([]);\n    const replyVisible = ref(false);\n    const current = ref({});\n    const replyContent = ref(\"\");\n    const loadData = async () => {\n      const res = await consultationApi.listAll();\n      if (res.code === 200) consultations.value = res.data || [];\n    };\n    const showReply = row => {\n      current.value = row;\n      replyContent.value = \"\";\n      replyVisible.value = true;\n    };\n    const showDetail = row => {\n      current.value = row;\n      replyContent.value = row.reply || \"\";\n      replyVisible.value = true;\n    };\n    const handleReply = async () => {\n      if (!replyContent.value.trim()) return ElMessage.warning(\"请输入回复内容\");\n      await consultationApi.reply({\n        id: current.value.id,\n        reply: replyContent.value\n      });\n      ElMessage.success(\"回复成功\");\n      replyVisible.value = false;\n      loadData();\n    };\n    onMounted(loadData);\n    const __returned__ = {\n      consultations,\n      replyVisible,\n      current,\n      replyContent,\n      loadData,\n      showReply,\n      showDetail,\n      handleReply,\n      ref,\n      onMounted,\n      get ElMessage() {\n        return ElMessage;\n      },\n      get consultationApi() {\n        return consultationApi;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","onMounted","ElMessage","consultationApi","consultations","replyVisible","current","replyContent","loadData","res","listAll","code","value","data","showReply","row","showDetail","reply","handleReply","trim","warning","id","success"],"sources":["D:/软件系统实训/diabetes-frontend/src/views/admin/ConsultationManage.vue"],"sourcesContent":["<template>\n  <div class=\"consult-manage\">\n    <h3 class=\"page-title\">咨询管理</h3>\n\n    <el-card shadow=\"never\">\n      <div class=\"table-wrap\">\n      <el-table :data=\"consultations\" stripe style=\"width: 100%\">\n        <el-table-column prop=\"id\" label=\"ID\" width=\"50\" />\n        <el-table-column prop=\"user_name\" label=\"用户\" width=\"70\" />\n        <el-table-column prop=\"content\" label=\"咨询内容\" min-width=\"120\" show-overflow-tooltip />\n        <el-table-column label=\"状态\" width=\"80\">\n          <template #default=\"scope\">\n            <el-tag :type=\"scope.row.status === '已回复' ? 'success' : 'warning'\" size=\"small\">{{ scope.row.status }}</el-tag>\n          </template>\n        </el-table-column>\n        <el-table-column label=\"操作\" width=\"80\" fixed=\"right\">\n          <template #default=\"scope\">\n            <el-button size=\"small\" type=\"primary\" @click=\"showReply(scope.row)\" v-if=\"scope.row.status === '待回复'\">回复</el-button>\n            <el-button size=\"small\" @click=\"showDetail(scope.row)\" v-else>查看</el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n      </div>\n    </el-card>\n\n    <el-dialog v-model=\"replyVisible\" :title=\"'回复咨询 #'+current.id\" width=\"95%\" top=\"10vh\">\n      <div class=\"consult-question\">\n        <strong>用户咨询：</strong>{{ current.content }}\n      </div>\n      <el-input v-model=\"replyContent\" type=\"textarea\" :rows=\"4\" placeholder=\"请输入回复内容...\" style=\"margin-top: 12px\" />\n      <template #footer>\n        <el-button @click=\"replyVisible = false\">取消</el-button>\n        <el-button type=\"primary\" @click=\"handleReply\">确认回复</el-button>\n      </template>\n    </el-dialog>\n  </div>\n</template>\n\n<script setup>\nimport { ref, onMounted } from \"vue\";\nimport { ElMessage } from \"element-plus\";\nimport { consultationApi } from \"../../api/index.js\";\n\nconst consultations = ref([]);\nconst replyVisible = ref(false);\nconst current = ref({});\nconst replyContent = ref(\"\");\n\nconst loadData = async () => {\n  const res = await consultationApi.listAll();\n  if (res.code === 200) consultations.value = res.data || [];\n};\n\nconst showReply = (row) => {\n  current.value = row;\n  replyContent.value = \"\";\n  replyVisible.value = true;\n};\n\nconst showDetail = (row) => {\n  current.value = row;\n  replyContent.value = row.reply || \"\";\n  replyVisible.value = true;\n};\n\nconst handleReply = async () => {\n  if (!replyContent.value.trim()) return ElMessage.warning(\"请输入回复内容\");\n  await consultationApi.reply({ id: current.value.id, reply: replyContent.value });\n  ElMessage.success(\"回复成功\");\n  replyVisible.value = false;\n  loadData();\n};\n\nonMounted(loadData);\n</script>\n\n<style scoped>\n.consult-manage { width: 100%; }\n.page-title { font-size: 22px; margin-bottom: 18px; font-family: var(--font-display); color: var(--gray-900); letter-spacing: 0.04em; }\n.consult-question { background: var(--primary-50); border-left: 3px solid var(--primary); padding: 12px 14px; border-radius: 0 10px 10px 0; font-size: 14px; line-height: 1.65; color: var(--gray-700); }\n.consult-question :deep(strong) { color: var(--primary-700); }\n</style>\n"],"mappings":"AAuCA,SAASA,GAAG,EAAEC,SAAS,QAAQ,KAAK;AACpC,SAASC,SAAS,QAAQ,cAAc;AACxC,SAASC,eAAe,QAAQ,oBAAoB;;;;;;;IAEpD,MAAMC,aAAa,GAAGJ,GAAG,CAAC,EAAE,CAAC;IAC7B,MAAMK,YAAY,GAAGL,GAAG,CAAC,KAAK,CAAC;IAC/B,MAAMM,OAAO,GAAGN,GAAG,CAAC,CAAC,CAAC,CAAC;IACvB,MAAMO,YAAY,GAAGP,GAAG,CAAC,EAAE,CAAC;IAE5B,MAAMQ,QAAQ,GAAG,MAAAA,CAAA,KAAY;MAC3B,MAAMC,GAAG,GAAG,MAAMN,eAAe,CAACO,OAAO,CAAC,CAAC;MAC3C,IAAID,GAAG,CAACE,IAAI,KAAK,GAAG,EAAEP,aAAa,CAACQ,KAAK,GAAGH,GAAG,CAACI,IAAI,IAAI,EAAE;IAC5D,CAAC;IAED,MAAMC,SAAS,GAAIC,GAAG,IAAK;MACzBT,OAAO,CAACM,KAAK,GAAGG,GAAG;MACnBR,YAAY,CAACK,KAAK,GAAG,EAAE;MACvBP,YAAY,CAACO,KAAK,GAAG,IAAI;IAC3B,CAAC;IAED,MAAMI,UAAU,GAAID,GAAG,IAAK;MAC1BT,OAAO,CAACM