{"ast":null,"code":"import { ref, onMounted } from \"vue\";\nimport { ElMessage, ElMessageBox } from \"element-plus\";\nimport { doctorApi } from \"../../api/index.js\";\nexport default {\n  __name: 'DoctorManage',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const doctors = ref([]);\n    const dialogVisible = ref(false);\n    const isEdit = ref(false);\n    const form = ref({\n      name: \"\",\n      department: \"\",\n      title: \"\",\n      phone: \"\",\n      goodAt: \"\",\n      introduction: \"\"\n    });\n    const loadData = async () => {\n      const res = await doctorApi.list();\n      if (res.code === 200) doctors.value = res.data || [];\n    };\n    const showAdd = () => {\n      isEdit.value = false;\n      form.value = {\n        name: \"\",\n        department: \"\",\n        title: \"\",\n        phone: \"\",\n        goodAt: \"\",\n        introduction: \"\"\n      };\n      dialogVisible.value = true;\n    };\n    const showEdit = row => {\n      isEdit.value = true;\n      form.value = {\n        ...row\n      };\n      dialogVisible.value = true;\n    };\n    const handleSubmit = async () => {\n      if (isEdit.value) {\n        await doctorApi.update(form.value);\n        ElMessage.success(\"更新成功\");\n      } else {\n        await doctorApi.add(form.value);\n        ElMessage.success(\"添加成功\");\n      }\n      dialogVisible.value = false;\n      loadData();\n    };\n    const handleDelete = async id => {\n      await ElMessageBox.confirm(\"确定删除？\", \"提示\", {\n        type: \"warning\"\n      });\n      await doctorApi.delete(id);\n      ElMessage.success(\"删除成功\");\n      loadData();\n    };\n    onMounted(loadData);\n    const __returned__ = {\n      doctors,\n      dialogVisible,\n      isEdit,\n      form,\n      loadData,\n      showAdd,\n      showEdit,\n      handleSubmit,\n      handleDelete,\n      ref,\n      onMounted,\n      get ElMessage() {\n        return ElMessage;\n      },\n      get ElMessageBox() {\n        return ElMessageBox;\n      },\n      get doctorApi() {\n        return doctorApi;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","onMounted","ElMessage","ElMessageBox","doctorApi","doctors","dialogVisible","isEdit","form","name","department","title","phone","goodAt","introduction","loadData","res","list","code","value","data","showAdd","showEdit","row","handleSubmit","update","success","add","handleDelete","id","confirm","type","delete"],"sources":["D:/软件系统实训/diabetes-frontend/src/views/admin/DoctorManage.vue"],"sourcesContent":["<template>\n  <div class=\"doctor-manage\">\n    <div class=\"page-header\">\n      <h3 class=\"page-title\">医师管理</h3>\n      <el-button type=\"primary\" size=\"small\" @click=\"showAdd\">新增医师</el-button>\n    </div>\n\n    <el-card shadow=\"never\">\n      <el-table :data=\"doctors\" stripe style=\"width: 100%\">\n        <el-table-column prop=\"id\" label=\"ID\" width=\"50\" />\n        <el-table-column prop=\"name\" label=\"姓名\" width=\"70\" />\n        <el-table-column prop=\"department\" label=\"科室\" width=\"80\" />\n        <el-table-column prop=\"title\" label=\"职称\" width=\"90\" />\n        <el-table-column prop=\"phone\" label=\"电话\" width=\"110\" />\n        <el-table-column label=\"操作\" width=\"100\" fixed=\"right\">\n          <template #default=\"scope\">\n            <el-button size=\"small\" @click=\"showEdit(scope.row)\">编辑</el-button>\n            <el-button size=\"small\" type=\"danger\" @click=\"handleDelete(scope.row.id)\">删除</el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n    </el-card>\n\n    <el-dialog v-model=\"dialogVisible\" :title=\"isEdit ? '编辑医师' : '新增医师'\" width=\"95%\" top=\"5vh\">\n      <el-form ref=\"formRef\" :model=\"form\" label-width=\"80px\">\n        <el-form-item label=\"姓名\" required><el-input v-model=\"form.name\" /></el-form-item>\n        <el-row :gutter=\"12\">\n          <el-col :span=\"12\"><el-form-item label=\"科室\"><el-input v-model=\"form.department\" /></el-form-item></el-col>\n          <el-col :span=\"12\"><el-form-item label=\"职称\"><el-input v-model=\"form.title\" /></el-form-item></el-col>\n        </el-row>\n        <el-form-item label=\"手机号\"><el-input v-model=\"form.phone\" /></el-form-item>\n        <el-form-item label=\"擅长领域\"><el-input v-model=\"form.goodAt\" type=\"textarea\" :rows=\"2\" /></el-form-item>\n        <el-form-item label=\"简介\"><el-input v-model=\"form.introduction\" type=\"textarea\" :rows=\"2\" /></el-form-item>\n      </el-form>\n      <template #footer>\n        <el-button @click=\"dialogVisible = false\">取消</el-button>\n        <el-button type=\"primary\" @click=\"handleSubmit\">保存</el-button>\n      </template>\n    </el-dialog>\n  </div>\n</template>\n\n<script setup>\nimport { ref, onMounted } from \"vue\";\nimport { ElMessage, ElMessageBox } from \"element-plus\";\nimport { doctorApi } from \"../../api/index.js\";\n\nconst doctors = ref([]);\nconst dialogVisible = ref(false);\nconst isEdit = ref(false);\nconst form = ref({ name: \"\", department: \"\", title: \"\", phone: \"\", goodAt: \"\", introduction: \"\" });\n\nconst loadData = async () => {\n  const res = await doctorApi.list();\n  if (res.code === 200) doctors.value = res.data || [];\n};\n\nconst showAdd = () => {\n  isEdit.value = false;\n  form.value = { name: \"\", department: \"\", title: \"\", phone: \"\", goodAt: \"\", introduction: \"\" };\n  dialogVisible.value = true;\n};\n\nconst showEdit = (row) => {\n  isEdit.value = true;\n  form.value = { ...row };\n  dialogVisible.value = true;\n};\n\nconst handleSubmit = async () => {\n  if (isEdit.value) {\n    await doctorApi.update(form.value);\n    ElMessage.success(\"更新成功\");\n  } else {\n    await doctorApi.add(form.value);\n    ElMessage.success(\"添加成功\");\n  }\n  dialogVisible.value = false;\n  loadData();\n};\n\nconst handleDelete = async (id) => {\n  await ElMessageBox.confirm(\"确定删除？\", \"提示\", { type: \"warning\" });\n  await doctorApi.delete(id);\n  ElMessage.success(\"删除成功\");\n  loadData();\n};\n\nonMounted(loadData);\n</script>\n\n<style scoped>\n.doctor-manage { max-width: 600px; margin: 0 auto; }\n.page-title { font-size: 22px; margin-bottom: 18px; font-family: var(--font-display); color: var(--gray-900); letter-spacing: 0.04em; }\n.page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18px; }\n.page-header .page-title { margin-bottom: 0; }\n</style>\n"],"mappings":"AA2CA,SAASA,GAAG,EAAEC,SAAS,QAAQ,KAAK;AACpC,SAASC,SAAS,EAAEC,YAAY,QAAQ,cAAc;AACtD,SAASC,SAAS,QAAQ,oBAAoB;;;;;;;IAE9C,MAAMC,OAAO,GAAGL,GAAG,CAAC,EAAE,CAAC;IACvB,MAAMM,aAAa,GAAGN,GAAG,CAAC,KAAK,CAAC;IAChC,MAAMO,MAAM,GAAGP,GAAG,CAAC,KAAK,CAAC;IACzB,MAAMQ,IAAI,GAAGR,GAAG,CAAC;MAAES,IAAI,EAAE,EAAE;MAAEC,UAAU,EAAE,EAAE;MAAEC,KAAK,EAAE,EAAE;MAAEC,KAAK,EAAE,EAAE;MAAEC,MAAM,EAAE,EAAE;MAAEC,YAAY,EAAE;IAAG,CAAC,CAAC;IAElG,MAAMC,QAAQ,GAAG,MAAAA,CAAA,KAAY;MAC3B,MAAMC,GAAG,GAAG,MAAMZ,SAAS,CAACa,IAAI,CAAC,CAAC;MAClC,IAAID,GAAG,CAACE,IAAI,KAAK,GAAG,EAAEb,OAAO,CAACc,KAAK,GAAGH,GAAG,CAACI,IAAI,IAAI,EAAE;IACtD,CAAC;IAED,MAAMC,OAAO,GAAGA,CAAA,KAAM;MACpBd,MAAM,CAACY,KAAK,GAAG,KAAK;MACpBX,IAAI,CAACW,KAAK,GAAG;QAAEV,IAAI,EAAE,EAAE;QAAEC,UAAU,EAAE,EAAE;QAAEC,KAAK,EAAE,EAAE;QAAEC,KAAK,EAAE,EAAE;QAAEC,MAAM,EAAE,EAAE;QAAEC,YAAY,EAAE;MAAG,CAAC;MAC7FR,aAAa,CAACa,KAAK,GAAG,IAAI;IAC5B,CAAC;IAED,MAAMG,QAAQ,GAAIC,GAAG,IAAK;MACxBhB,MAAM,CAACY,KAAK,GAAG,IAAI;MACnBX,IAAI,CAACW,KAAK,GAAG;QAAE,GAAGI;MAAI,CAAC;MACvBjB,aAAa,CAACa,KAAK,GAAG,IAAI;IAC5B,CAAC;IAED,MAAMK,YAAY,GAAG,MAAAA,CAAA,KAAY;MAC/B,IAAIjB,MAAM,CAACY,KAAK,EAAE;QAChB,MAAMf,SAAS,CAACqB,MAAM,CAACjB,IAAI,CAACW,KAAK,CAAC;QAClCjB,SAAS,CAACwB,OAAO,CAAC,MAAM,CAAC;MAC3B,CAAC,MAAM;QACL,MAAMtB,SAAS,CAACuB,GAAG,CAACnB,IAAI,CAACW,KAAK,CAAC;QAC/BjB,SAAS,CAACwB,OAAO,CAAC,MAAM,CAAC;MAC3B;MACApB,aAAa,CAACa,KAAK,GAAG,KAAK;MAC3BJ,QAAQ,CAAC,CAAC